<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap');
        body { font-family: 'Tajawal', sans-serif; transition: all 0.3s ease; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <div class="min-h-screen p-4 md:p-6 lg:p-8">
        
        <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-4">
            <div class="text-center md:text-right">
                <h1 class="text-3xl font-extrabold text-gray-900 leading-tight">Pixel POS <span class="text-blue-600">Dashboard</span></h1>
                <p class="text-gray-500 mt-1">
                    <i class="far fa-calendar-alt ml-1"></i> <%= data.currentDate %> | 
                    <i class="far fa-clock ml-1"></i> <span id="live-time"><%= data.currentTime %></span>
                </p>
            </div>
            <div class="flex items-center gap-3">
                <button onclick="window.location.reload()" class="bg-white border border-gray-200 shadow-sm px-5 py-2.5 rounded-xl text-gray-700 hover:bg-gray-100 transition flex items-center gap-2">
                    <i class="fas fa-sync-alt"></i> تحديث
                </button>
                <a href="/dashboard/export/pdf" class="bg-blue-600 shadow-lg shadow-blue-200 px-5 py-2.5 rounded-xl text-white hover:bg-blue-700 transition flex items-center gap-2">
                    <i class="fas fa-file-export"></i> تصدير PDF
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-blue-50 rounded-full -mr-12 -mt-12 transition-transform group-hover:scale-110"></div>
                <p class="text-sm font-medium text-gray-400 mb-1 relative">مبيعات اليوم</p>
                <h3 class="text-2xl font-bold text-gray-800 relative tracking-tight"><%= data.quickStats.todaySales.toLocaleString() %> <span class="text-sm font-normal text-gray-400">د.ع</span></h3>
                <div class="mt-4 flex items-center text-xs text-blue-600 font-bold bg-blue-50 w-fit px-2 py-1 rounded-lg">
                    <i class="fas fa-arrow-up ml-1"></i> <%= data.quickStats.todayInvoices %> فواتير
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-green-50 rounded-full -mr-12 -mt-12 transition-transform group-hover:scale-110"></div>
                <p class="text-sm font-medium text-gray-400 mb-1 relative">صافي الصندوق</p>
                <h3 class="text-2xl font-bold text-gray-800 relative tracking-tight"><%= data.quickStats.cashNet.toLocaleString() %> <span class="text-sm font-normal text-gray-400">د.ع</span></h3>
                <div class="mt-4 flex items-center text-xs text-green-600 font-bold bg-green-50 w-fit px-2 py-1 rounded-lg">
                    وارد: <%= data.quickStats.cashIn.toLocaleString() %>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-red-50 rounded-full -mr-12 -mt-12 transition-transform group-hover:scale-110"></div>
                <p class="text-sm font-medium text-gray-400 mb-1 relative">ديون العملاء</p>
                <h3 class="text-2xl font-bold text-gray-800 relative tracking-tight text-red-600"><%= data.quickStats.customerDebts.toLocaleString() %> <span class="text-sm font-normal text-gray-400">د.ع</span></h3>
                <div class="mt-4 flex items-center text-xs text-red-600 font-bold bg-red-50 w-fit px-2 py-1 rounded-lg">
                    <i class="fas fa-users ml-1"></i> <%= data.quickStats.debtorsCount %> عملاء
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-yellow-50 rounded-full -mr-12 -mt-12 transition-transform group-hover:scale-110"></div>
                <p class="text-sm font-medium text-gray-400 mb-1 relative">قيمة المخزون</p>
                <h3 class="text-2xl font-bold text-gray-800 relative tracking-tight"><%= data.quickStats.inventoryValue.toLocaleString() %> <span class="text-sm font-normal text-gray-400">د.ع</span></h3>
                <div class="mt-4 flex items-center text-xs text-yellow-600 font-bold bg-yellow-50 w-fit px-2 py-1 rounded-lg">
                    <%= data.quickStats.lowStockCount %> منتجات منخفضة
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
            <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-bold text-gray-700 text-lg">تحليل المبيعات الأسبوعي</h3>
                    <div class="flex gap-2">
                        <span class="w-3 h-3 bg-blue-500 rounded-full"></span>
                        <span class="text-xs text-gray-400 font-medium italic">إجمالي الوارد اليومي</span>
                    </div>
                </div>
                <div class="relative h-64">
                    <canvas id="weeklyChart"></canvas>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center">
                <h3 class="font-bold text-gray-700 text-lg mb-8 w-full">توزيع المبيعات</h3>
                <div class="relative h-64 w-full flex justify-center">
                    <canvas id="distributionChart"></canvas>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
            <div class="xl:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-5 border-b border-gray-50 flex justify-between items-center">
                    <h3 class="font-bold text-gray-700 underline decoration-blue-500 decoration-2 underline-offset-8">آخر المبيعات</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-right">
                        <thead>
                            <tr class="text-gray-400 text-xs font-bold uppercase tracking-wider bg-gray-50/50">
                                <th class="px-6 py-4">المسلسل</th>
                                <th class="px-6 py-4">العميل</th>
                                <th class="px-6 py-4">المبلغ</th>
                                <th class="px-6 py-4 text-center">الحالة</th>
                                <th class="px-6 py-4">التوقيت</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% data.recentSales.forEach(sale => { %>
                            <tr class="hover:bg-blue-50/30 transition duration-150">
                                <td class="px-6 py-4 font-mono text-sm text-gray-500"><%= sale.invoiceNumber %></td>
                                <td class="px-6 py-4 font-bold text-gray-700"><%= sale.customer %></td>
                                <td class="px-6 py-4 font-bold text-blue-600"><%= sale.total.toLocaleString() %></td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold <%= sale.type === 'CASH' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                                        <%= sale.type === 'CASH' ? 'نقدي' : 'آجل' %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-xs text-gray-400"><%= sale.time %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-5 border-b border-gray-50 bg-gray-50/50">
                    <h3 class="font-bold text-gray-700">الأكثر مبيعاً هذا الشهر</h3>
                </div>
                <div class="p-5 space-y-6">
                    <% data.topProducts.forEach((product, index) => { %>
                    <div class="flex items-center gap-4">
                        <div class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-100 text-gray-500 font-bold text-xs">
                            <%= index + 1 %>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-bold text-gray-800 truncate w-32"><%= product.name %></p>
                            <div class="w-full bg-gray-100 h-1.5 rounded-full mt-1.5 overflow-hidden">
                                <div class="bg-blue-500 h-full rounded-full" style="width: <%= Math.min(100, (product.quantity/data.quickStats.todayInvoices)*10) %>%"></div>
                            </div>
                        </div>
                        <div class="text-left">
                            <p class="text-xs font-bold text-green-600"><%= product.revenue.toLocaleString() %></p>
                            <p class="text-[10px] text-gray-400"><%= product.quantity %> قطعة</p>
                        </div>
                    </div>
                    <% }) %>
                    <% if(data.topProducts.length === 0) { %>
                        <p class="text-center text-gray-400 py-10">لا يوجد بيانات مبيعات كافية</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        // تخزين البيانات في متغيرات JS لتجنب مشاكل الـ Syntax في المحرر
        const labelsWeekly = <%- JSON.stringify(data.charts.weeklyLabels || []) %>;
        const dataWeekly = <%- JSON.stringify(data.charts.weeklySales || []) %>;
        const cashDist = <%= data.charts.distribution.cash || 0 %>;
        const debtDist = <%= data.charts.distribution.debt || 0 %>;

        // مبيعات الأسبوع
        const ctxWeekly = document.getElementById('weeklyChart').getContext('2d');
        new Chart(ctxWeekly, {
            type: 'line',
            data: {
                labels: labelsWeekly,
                datasets: [{
                    label: 'المبيعات',
                    data: dataWeekly,
                    borderColor: '#3b82f6',
                    borderWidth: 3,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#3b82f6',
                    pointHoverRadius: 6,
                    backgroundColor: (context) => {
                        const gradient = context.chart.ctx.createLinearGradient(0, 0, 0, 400);
                        gradient.addColorStop(0, 'rgba(59, 130, 246, 0.2)');
                        gradient.addColorStop(1, 'rgba(59, 130, 246, 0)');
                        return gradient;
                    },
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } },
                    y: { 
                        beginAtZero: true,
                        grid: { borderDash: [5, 5] },
                        ticks: { callback: (value) => value.toLocaleString() }
                    }
                }
            }
        });

        // توزيع المبيعات (Doughnut)
        const ctxDist = document.getElementById('distributionChart').getContext('2d');
        new Chart(ctxDist, {
            type: 'doughnut',
            data: {
                labels: ['نقدي', 'آجل'],
                datasets: [{
                    data: [cashDist, debtDist],
                    backgroundColor: ['#10b981', '#ef4444'],
                    hoverOffset: 10,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                }
            }
        });
    </script>
</body>
</html>