<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
    <style>
        /* ==================== أنماط مخصصة للبطاقات ==================== */
        .report-card {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(203, 213, 225, 0.3);
            position: relative;
            overflow: hidden;
            will-change: transform, border-color, box-shadow;
        }

        .dark .report-card {
            border-color: rgba(51, 65, 85, 0.5);
        }

        .report-card:hover {
            transform: translateY(-8px) scale(1.02);
            border-color: #3b82f6;
            box-shadow: 0 25px 50px -12px rgba(59, 130, 246, 0.25);
        }

        .icon-wrapper {
            width: 70px;
            height: 70px;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            will-change: transform;
        }

        .report-card:hover .icon-wrapper {
            transform: scale(1.1) rotate(5deg);
        }

        .card-arrow {
            opacity: 0;
            transform: translateX(10px);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .report-card:hover .card-arrow {
            opacity: 1;
            transform: translateX(0);
        }

        /* تأثير الخلفية المتوهجة */
        .report-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.1), transparent 70%);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .report-card:hover::after {
            opacity: 1;
        }

        /* أنماط للبطاقة المميزة */
        .featured-card {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            transition: background 0.4s ease;
        }

        .dark .featured-card {
            background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
        }

        /* تنسيق النصوص */
        .section-title {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ==================== أنماط التحول السلس ==================== */
        body, body * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.2s ease, box-shadow 0.3s ease;
        }

        /* تحسين أداء التحولات */
        .bg-white, .dark\:bg-pixelCard, .bg-gray-50, .dark\:bg-pixelDark,
        .border-slate-100, .dark\:border-slate-800,
        .text-slate-900, .dark\:text-slate-100,
        .text-slate-500, .dark\:text-slate-400,
        .bg-blue-100, .dark\:bg-blue-500\/10 {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease !important;
        }

        /* إخفاء شريط التمرير الجانبي */
        .custom-scroll {
            scrollbar-width: none; /* Firefox */
            -ms-overflow-style: none; /* IE and Edge */
        }

        .custom-scroll::-webkit-scrollbar {
            display: none; /* Chrome, Safari, Opera */
        }

        /* ضمان سلاسة التمرير */
        .smooth-scroll {
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
        }

        /* تحسين مظهر النص في الوضع الليلي */
        .dark .text-slate-400 {
            color: rgba(148, 163, 184, 0.9);
        }

        .dark .text-slate-500 {
            color: rgba(100, 116, 139, 0.9);
        }

        /* تأثيرات إضافية للتحول */
        .theme-transition {
            transition-property: background-color, border-color, color, fill, stroke, opacity, box-shadow, transform;
            transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
            transition-duration: 300ms;
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-pixelDark text-slate-900 dark:text-slate-100 min-h-screen theme-transition">
    <div class="flex h-screen overflow-hidden">
        <!-- الشريط الجانبي (بصمة Pixel) -->
        <%- include('partials/sidebar') %>

        <!-- المحتوى الرئيسي -->
        <main class="flex-1 flex flex-col overflow-hidden">
            <!-- شريط التنقل العلوي -->
            <%- include('partials/navbar') %>

            <!-- محتوى الصفحة - مع إخفاء شريط التمرير -->
            <div class="flex-1 overflow-y-auto smooth-scroll custom-scroll p-8" style="scrollbar-width: none; -ms-overflow-style: none;">
                <!-- رأس الصفحة -->
                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-500/10 rounded-2xl flex items-center justify-center theme-transition">
                            <i data-lucide="layout-dashboard" class="w-6 h-6 text-blue-600 dark:text-blue-400"></i>
                        </div>
                        <div>
                            <h1 class="text-3xl font-black italic">
                                <span class="bg-gradient-to-l from-blue-600 to-purple-600 bg-clip-text text-transparent">
                                    مركز التقارير
                                </span>
                            </h1>
                            <p class="text-slate-500 dark:text-slate-400 font-medium mt-2 flex items-center gap-2 theme-transition">
                                <i data-lucide="info" class="w-4 h-4"></i>
                                اختر التقرير الذي ترغب بمراجعته من القائمة أدناه
                            </p>
                        </div>
                    </div>

                    <!-- إحصائيات سريعة -->
                    <div class="flex flex-wrap gap-4 mt-6">
                        <div class="bg-white dark:bg-pixelCard px-5 py-3 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm theme-transition">
                            <span class="text-xs font-bold text-slate-400 block mb-1">آخر تحديث</span>
                            <span class="font-black text-sm flex items-center gap-2">
                                <i data-lucide="clock" class="w-4 h-4 text-blue-600"></i>
                                <%= new Date().toLocaleString('ar-IQ') %>
                            </span>
                        </div>
                        <div class="bg-white dark:bg-pixelCard px-5 py-3 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm theme-transition">
                            <span class="text-xs font-bold text-slate-400 block mb-1">عدد التقارير</span>
                            <span class="font-black text-sm flex items-center gap-2">
                                <i data-lucide="file-text" class="w-4 h-4 text-green-600"></i>
                                5 تقارير متاحة
                            </span>
                        </div>
                    </div>
                </div>

                <!-- شبكة التقارير -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    
                    <!-- تقرير المبيعات -->
                    <a href="/reports/sales" class="report-card bg-white dark:bg-pixelCard p-8 rounded-[2rem] shadow-lg relative group theme-transition">
                        <div class="relative z-10">
                            <div class="icon-wrapper bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 mb-8 theme-transition">
                                <i data-lucide="trending-up" class="w-8 h-8"></i>
                            </div>
                            
                            <h3 class="text-2xl font-black italic mb-3 group-hover:text-blue-600 transition-colors theme-transition">
                                تقرير المبيعات
                            </h3>
                            
                            <p class="text-slate-400 dark:text-slate-500 text-sm leading-relaxed mb-8 font-medium theme-transition">
                                عرض تفصيلي للمبيعات اليومية، الأرباح، وإحصائيات فواتير الكاشير مع إمكانية التصفية حسب التاريخ.
                            </p>
                            
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-slate-300 dark:text-slate-600 uppercase tracking-wider theme-transition">
                                    5 تقارير فرعية
                                </span>
                                <div class="card-arrow flex items-center gap-2 text-blue-600 font-black text-sm">
                                    <span>عرض التقرير</span>
                                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- تقرير المخزون -->
                    <a href="/reports/inventory" class="report-card bg-white dark:bg-pixelCard p-8 rounded-[2rem] shadow-lg relative group theme-transition">
                        <div class="relative z-10">
                            <div class="icon-wrapper bg-orange-50 dark:bg-orange-500/10 text-orange-600 dark:text-orange-400 mb-8 theme-transition">
                                <i data-lucide="boxes" class="w-8 h-8"></i>
                            </div>
                            
                            <h3 class="text-2xl font-black italic mb-3 group-hover:text-orange-600 transition-colors theme-transition">
                                حالة المخزون
                            </h3>
                            
                            <p class="text-slate-400 dark:text-slate-500 text-sm leading-relaxed mb-8 font-medium theme-transition">
                                مراقبة كميات المواد، المنتجات منخفضة المخزون، تنبيهات النواقص، وقيمة المخزون الإجمالية.
                            </p>
                            
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-slate-300 dark:text-slate-600 uppercase tracking-wider theme-transition">
                                    4 تقارير فرعية
                                </span>
                                <div class="card-arrow flex items-center gap-2 text-orange-600 font-black text-sm">
                                    <span>عرض التقرير</span>
                                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- تقرير الديون -->
                    <a href="/reports/debts" class="report-card bg-white dark:bg-pixelCard p-8 rounded-[2rem] shadow-lg relative group theme-transition">
                        <div class="relative z-10">
                            <div class="icon-wrapper bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 mb-8 theme-transition">
                                <i data-lucide="credit-card" class="w-8 h-8"></i>
                            </div>
                            
                            <h3 class="text-2xl font-black italic mb-3 group-hover:text-red-600 transition-colors theme-transition">
                                الديون والحسابات
                            </h3>
                            
                            <p class="text-slate-400 dark:text-slate-500 text-sm leading-relaxed mb-8 font-medium theme-transition">
                                كشف حسابات العملاء، مديونيات الموردين، جدول التسديد، وتقارير الديون الشهرية.
                            </p>
                            
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-slate-300 dark:text-slate-600 uppercase tracking-wider theme-transition">
                                    3 تقارير فرعية
                                </span>
                                <div class="card-arrow flex items-center gap-2 text-red-600 font-black text-sm">
                                    <span>عرض التقرير</span>
                                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- تقرير النقدية -->
                    <a href="/reports/cash" class="report-card bg-white dark:bg-pixelCard p-8 rounded-[2rem] shadow-lg relative group theme-transition">
                        <div class="relative z-10">
                            <div class="icon-wrapper bg-green-50 dark:bg-green-500/10 text-green-600 dark:text-green-400 mb-8 theme-transition">
                                <i data-lucide="wallet" class="w-8 h-8"></i>
                            </div>
                            
                            <h3 class="text-2xl font-black italic mb-3 group-hover:text-green-600 transition-colors theme-transition">
                                حركة الصندوق
                            </h3>
                            
                            <p class="text-slate-400 dark:text-slate-500 text-sm leading-relaxed mb-8 font-medium theme-transition">
                                متابعة المقبوضات والمصروفات اليومية، صافي الوارد المالي، وتقارير الخزينة.
                            </p>
                            
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-slate-300 dark:text-slate-600 uppercase tracking-wider theme-transition">
                                    3 تقارير فرعية
                                </span>
                                <div class="card-arrow flex items-center gap-2 text-green-600 font-black text-sm">
                                    <span>عرض التقرير</span>
                                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- تقرير المشتريات -->
                    <a href="/reports/purchases" class="report-card bg-white dark:bg-pixelCard p-8 rounded-[2rem] shadow-lg relative group theme-transition">
                        <div class="relative z-10">
                            <div class="icon-wrapper bg-purple-50 dark:bg-purple-500/10 text-purple-600 dark:text-purple-400 mb-8 theme-transition">
                                <i data-lucide="truck" class="w-8 h-8"></i>
                            </div>
                            
                            <h3 class="text-2xl font-black italic mb-3 group-hover:text-purple-600 transition-colors theme-transition">
                                تقارير المشتريات
                            </h3>
                            
                            <p class="text-slate-400 dark:text-slate-500 text-sm leading-relaxed mb-8 font-medium theme-transition">
                                تحليل المشتريات، فواتير الشراء، وأداء الموردين مع إحصائيات التوريد.
                            </p>
                            
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-slate-300 dark:text-slate-600 uppercase tracking-wider theme-transition">
                                    3 تقارير فرعية
                                </span>
                                <div class="card-arrow flex items-center gap-2 text-purple-600 font-black text-sm">
                                    <span>عرض التقرير</span>
                                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                                </div>
                            </div>
                        </div>
                    </a>

                   
                </div>

                <!-- تذييل الصفحة -->
                <%- include('partials/footer') %>
        </main>
    </div>

    <!-- تضمين Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        // تهيئة الأيقونات
        lucide.createIcons();

        // مراقبة تغيير الوضع (light/dark)
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.attributeName === 'class') {
                    // إضافة تأثير سلس عند تغيير الوضع
                    document.body.style.transition = 'background-color 0.3s ease';
                    setTimeout(() => {
                        document.body.style.transition = '';
                    }, 300);
                }
            });
        });

        observer.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ['class']
        });
    </script>
</body>
</html>