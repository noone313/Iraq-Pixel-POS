<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
    <style>
        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }
        .dark .glass-card {
            background: rgba(30, 41, 59, 0.7);
            border-color: rgba(71, 85, 105, 0.3);
        }
        .hero-stat {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        }
        .progress-bar { transition: width 1s ease-in-out; }
        .tabular-nums { font-variant-numeric: tabular-nums; }
        @media print { .no-print { display: none !important; } .print-p-0 { padding: 0 !important; } }
    </style>
</head>

<body class="bg-slate-50 dark:bg-pixelDark text-slate-900 dark:text-slate-100 min-h-screen">
    <div class="flex">
        <%- include('partials/sidebar') %>

        <main class="flex-1 p-4 lg:p-8 print-p-0">
            <%- include('partials/navbar') %>

            <div class="max-w-7xl mx-auto">
                
                <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-6">
                    <div>
                        <h1 class="text-4xl font-black italic text-slate-800 dark:text-white">📊 التقرير المالي الشامل</h1>
                        <p class="text-slate-500 font-bold mt-1">تحليل الأداء المالي للفترة المحددة</p>
                    </div>

                    <form method="GET" class="flex flex-wrap items-center gap-3 bg-white dark:bg-pixelCard p-3 rounded-[2rem] shadow-sm border border-slate-200 dark:border-slate-800 no-print">
                        <div class="flex items-center gap-2">
                            <input type="date" name="fromDate" value="<%= filters.fromDate %>" class="bg-slate-50 dark:bg-slate-900 px-4 py-2 rounded-xl border-none text-sm font-bold outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                            <span class="text-slate-400 font-black">إلى</span>
                            <input type="date" name="toDate" value="<%= filters.toDate %>" class="bg-slate-50 dark:bg-slate-900 px-4 py-2 rounded-xl border-none text-sm font-bold outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>
                        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-xl font-black text-sm shadow-lg shadow-blue-500/20 transition-all active:scale-95">
                            تحديث التقرير
                        </button>
                        <button type="button" onclick="window.print()" class="p-2.5 bg-slate-100 dark:bg-slate-800 text-slate-500 rounded-xl hover:text-blue-500 transition-colors">
                            <i data-lucide="printer" class="w-5 h-5"></i>
                        </button>
                    </form>
                </div>

                <% if (!report || report.totalSales === 0) { %>
                    <div class="flex flex-col items-center justify-center py-32 opacity-30 italic font-black">
                        <i data-lucide="folder-search" class="w-20 h-20 mb-4 text-blue-500"></i>
                        <p class="text-2xl">لا توجد بيانات مالية للفترة المختارة</p>
                    </div>
                <% } else { %>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                    <div class="glass-card p-6 rounded-[2.5rem] relative overflow-hidden">
                        <div class="flex justify-between items-start mb-4">
                            <div class="p-3 bg-blue-100 dark:bg-blue-500/10 rounded-2xl text-blue-600"><i data-lucide="shopping-bag" class="w-5 h-5"></i></div>
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">إجمالي المبيعات</span>
                        </div>
                        <div class="text-3xl font-black tabular-nums"><%= report.totalSales.toLocaleString() %> <small class="text-xs font-normal opacity-50">د.ع</small></div>
                    </div>

                    <div class="hero-stat p-6 rounded-[2.5rem] text-white shadow-xl shadow-blue-500/10 relative">
                        <div class="flex justify-between items-start mb-4">
                            <div class="p-3 bg-white/10 rounded-2xl text-emerald-400"><i data-lucide="trending-up" class="w-5 h-5"></i></div>
                            <span class="text-slate-400 text-[10px] font-black uppercase tracking-widest">صافي الربح</span>
                        </div>
                        <div class="text-3xl font-black tabular-nums text-emerald-400"><%= report.netProfit.toLocaleString() %> <small class="text-xs font-normal opacity-70">د.ع</small></div>
                        <i data-lucide="sparkles" class="absolute -left-2 -bottom-2 w-16 h-16 opacity-5"></i>
                    </div>

                    <div class="glass-card p-6 rounded-[2.5rem]">
                        <div class="flex justify-between items-start mb-4">
                            <div class="p-3 bg-purple-100 dark:bg-purple-500/10 rounded-2xl text-purple-600"><i data-lucide="pie-chart" class="w-5 h-5"></i></div>
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">هامش الربح</span>
                        </div>
                        <div class="text-3xl font-black tabular-nums"><%= report.profitMargin %><small class="text-lg">%</small></div>
                        <div class="w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full mt-4 overflow-hidden">
                            <div class="bg-purple-500 h-full progress-bar" style="width: <%= report.profitMargin %>%"></div>
                        </div>
                    </div>

                    <div class="glass-card p-6 rounded-[2.5rem]">
                        <div class="flex justify-between items-start mb-4">
                            <div class="p-3 bg-orange-100 dark:bg-orange-500/10 rounded-2xl text-orange-600"><i data-lucide="banknote" class="w-5 h-5"></i></div>
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">كفاءة التحصيل</span>
                        </div>
                        <div class="text-3xl font-black tabular-nums"><%= report.collectionRate %><small class="text-lg">%</small></div>
                        <div class="w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full mt-4 overflow-hidden">
                            <div class="bg-orange-500 h-full progress-bar" style="width: <%= report.collectionRate %>%"></div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
                    
                    <div class="lg:col-span-2 glass-card p-8 rounded-[3rem]">
                        <h3 class="text-xl font-black mb-8 flex items-center gap-3">
                            <i data-lucide="layers" class="text-blue-500 w-6 h-6"></i>
                            توزيع التكاليف والمصاريف
                        </h3>
                        <div class="space-y-6">
                            <div class="flex justify-between items-center p-6 bg-slate-50 dark:bg-slate-900/50 rounded-3xl group">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 bg-white dark:bg-slate-800 rounded-2xl shadow-sm flex items-center justify-center text-slate-400 group-hover:text-blue-500 transition-colors">
                                        <i data-lucide="box"></i>
                                    </div>
                                    <div>
                                        <div class="font-black text-slate-800 dark:text-white">تكلفة البضاعة المباعة</div>
                                        <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Cost of Goods Sold</div>
                                    </div>
                                </div>
                                <div class="text-xl font-black tabular-nums"><%= report.totalCost.toLocaleString() %></div>
                            </div>

                            <div class="flex justify-between items-center p-6 bg-red-50 dark:bg-red-500/5 rounded-3xl group">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 bg-white dark:bg-slate-800 rounded-2xl shadow-sm flex items-center justify-center text-red-400">
                                        <i data-lucide="external-link"></i>
                                    </div>
                                    <div>
                                        <div class="font-black text-red-600">إجمالي المصاريف</div>
                                        <div class="text-[10px] text-red-400 font-bold uppercase tracking-wider">General Expenses</div>
                                    </div>
                                </div>
                                <div class="text-xl font-black tabular-nums text-red-600"><%= report.totalExpenses.toLocaleString() %></div>
                            </div>

                            <div class="flex justify-between items-center p-6 bg-emerald-50 dark:bg-emerald-500/5 rounded-3xl group border-t-4 border-emerald-500/20">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 bg-white dark:bg-slate-800 rounded-2xl shadow-sm flex items-center justify-center text-emerald-500">
                                        <i data-lucide="coins"></i>
                                    </div>
                                    <div>
                                        <div class="font-black text-emerald-600">الربح الإجمالي</div>
                                        <div class="text-[10px] text-emerald-400 font-bold uppercase tracking-wider">Gross Profit</div>
                                    </div>
                                </div>
                                <div class="text-xl font-black tabular-nums text-emerald-600"><%= report.grossProfit.toLocaleString() %></div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-6">
                        <div class="glass-card p-8 rounded-[3rem] flex-1 flex flex-col justify-center border-l-8 border-red-500">
                            <div class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em] mb-2">ديون العملاء (مستحقات لنا)</div>
                            <div class="text-4xl font-black tabular-nums text-red-500"><%= report.customerDebt.toLocaleString() %></div>
                            <div class="mt-4 flex items-center gap-2 text-slate-400 text-xs font-bold">
                                <i data-lucide="users" class="w-4 h-4"></i>
                                إجمالي الذمم المدينة
                            </div>
                        </div>

                        <div class="glass-card p-8 rounded-[3rem] flex-1 flex flex-col justify-center border-l-8 border-orange-500">
                            <div class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em] mb-2">ديون الموردين (التزامات علينا)</div>
                            <div class="text-4xl font-black tabular-nums text-orange-500"><%= report.supplierDebt.toLocaleString() %></div>
                            <div class="mt-4 flex items-center gap-2 text-slate-400 text-xs font-bold">
                                <i data-lucide="truck" class="w-4 h-4"></i>
                                إجمالي الذمم الدائنة
                            </div>
                        </div>
                    </div>
                </div>

                <div class="glass-card rounded-[3rem] overflow-hidden mb-10 shadow-xl border-none">
                    <div class="p-8 bg-slate-900 text-white flex justify-between items-center">
                        <h3 class="text-xl font-black flex items-center gap-3 italic">
                            <i data-lucide="award" class="text-yellow-400"></i>
                            المنتجات الأكثر مبيعاً (من حيث الإيراد)
                        </h3>
                        <span class="text-[10px] font-bold bg-white/10 px-4 py-1 rounded-full uppercase">Top Performance</span>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-right">
                            <thead>
                                <tr class="bg-slate-50 dark:bg-slate-800/50 text-slate-400 text-[10px] font-black uppercase tracking-widest">
                                    <th class="p-6">المنتج</th>
                                    <th class="p-6 text-center">الكمية المباعة</th>
                                    <th class="p-6 text-left">إجمالي الإيرادات</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                                <% report.topProducts.forEach((product, index) => { %>
                                    <tr class="hover:bg-blue-50/30 dark:hover:bg-blue-500/5 transition-all">
                                        <td class="p-6">
                                            <div class="flex items-center gap-4">
                                                <span class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-xs font-black text-slate-400">
                                                    <%= index + 1 %>
                                                </span>
                                                <div class="font-black text-slate-800 dark:text-white"><%= product.name %></div>
                                            </div>
                                        </td>
                                        <td class="p-6 text-center font-bold text-slate-500 tabular-nums">
                                            <%= product.qty %> <small class="text-[10px]">قطعة</small>
                                        </td>
                                        <td class="p-6 text-left">
                                            <div class="font-black tabular-nums text-blue-600"><%= product.revenue.toLocaleString() %> <small class="text-[10px] opacity-50">د.ع</small></div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <% } %>
            </div>
        </main>
    </div>

    <script>
        window.addEventListener('load', () => {
            if(typeof lucide !== 'undefined') lucide.createIcons();
        });
    </script>
</body>
</html>