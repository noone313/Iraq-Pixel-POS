<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-gray-50 dark:bg-pixelDark text-slate-900 dark:text-slate-100 min-h-screen flex flex-col">

    <%- include('partials/navbar') %>

    <main class="flex-1 flex items-center justify-center p-6">
        <div class="w-full max-w-md">
            <div class="flex flex-col items-center text-center mb-8">
                <div class="mb-4 p-4 bg-pixelBlue text-white rounded-3xl shadow-xl shadow-blue-500/20">
                    <i data-lucide="shield-check" class="w-10 h-10"></i>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter">
                    PIXEL <span class="text-pixelBlue">IRAQ</span>
                </h1>
                <p class="text-slate-500 mt-2 font-medium">بوابة الدخول الموحدة للنظام</p>
            </div>

            <div class="bg-white dark:bg-pixelCard p-8 rounded-[2.5rem] shadow-2xl shadow-blue-900/10 border border-gray-100 dark:border-slate-800">
                
                <% if (locals.error) { %>
                    <div class="mb-6 p-4 bg-red-50 dark:bg-red-500/10 border border-red-100 dark:border-red-500/20 rounded-2xl flex items-center gap-3 text-red-600 text-sm font-bold">
                        <i data-lucide="alert-circle" class="w-5 h-5"></i>
                        <%= error %>
                    </div>
                <% } %>

                <form action="/login" method="POST" class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-sm font-bold px-1 text-slate-600 dark:text-slate-400">اسم المستخدم</label>
                        <div class="relative group">
                            <i data-lucide="user" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 group-focus-within:text-pixelBlue transition-colors"></i>
                            <input type="text" name="username" required
                                class="w-full bg-gray-50 dark:bg-slate-900/50 border border-gray-200 dark:border-slate-800 p-4 pr-12 rounded-2xl focus:outline-none focus:ring-2 focus:ring-pixelBlue/20 focus:border-pixelBlue transition-all"
                                placeholder="ادخل اسم المستخدم">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold px-1 text-slate-600 dark:text-slate-400">كلمة المرور</label>
                        <div class="relative group">
                            <i data-lucide="lock" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 group-focus-within:text-pixelBlue transition-colors"></i>
                            <input type="password" name="password" required
                                class="w-full bg-gray-50 dark:bg-slate-900/50 border border-gray-200 dark:border-slate-800 p-4 pr-12 rounded-2xl focus:outline-none focus:ring-2 focus:ring-pixelBlue/20 focus:border-pixelBlue transition-all"
                                placeholder="••••••••">
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-pixelBlue hover:bg-blue-600 text-white p-4 rounded-2xl font-black text-lg shadow-lg shadow-blue-500/30 transition-all hover:scale-[1.02] active:scale-95 flex items-center justify-center gap-2">
                        <span>تسجيل الدخول</span>
                        <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    </button>
                </form>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script>lucide.createIcons();</script>
</body>
</html>