<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
    <style>
        /* تثبيت الفاتورة وجعلها ثابتة */
        .cart-sidebar {
            position: sticky;
            top: 20px;
            height: fit-content;
            max-height: calc(100vh - 40px);
            display: flex;
            flex-direction: column;
        }
        
        .cart-container { 
            flex: 1;
            overflow-y: auto;
            min-height: 300px;
            max-height: 400px;
        }
        
        .custom-scroll::-webkit-scrollbar { width: 4px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #3b82f6; border-radius: 10px; }
        
        .product-item:focus { 
            border-color: #3b82f6; 
            outline: none; 
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.3); 
        }

        @keyframes scan-flash {
            0% { transform: scale(1); background-color: rgba(59, 130, 246, 0.2); }
            50% { transform: scale(1.02); }
            100% { transform: scale(1); background-color: transparent; }
        }
        .flash-success { animation: scan-flash 0.4s ease-out; }

        .barcode-error-msg {
            position: absolute;
            bottom: -25px;
            right: 0;
            background: #ef4444;
            color: white;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: bold;
            opacity: 0;
            transition: opacity 0.2s;
            pointer-events: none;
        }
        .barcode-error-msg.show { opacity: 1; }

        /* تحسين ظهور الفاتورة */
        .cart-header {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white;
            border-radius: 2rem 2rem 0 0;
        }
        
        .cart-footer {
            background: linear-gradient(135deg, #f8fafc, #f1f5f9);
            border-radius: 0 0 2rem 2rem;
        }
        
        .dark .cart-footer {
            background: linear-gradient(135deg, #1e293b, #0f172a);
        }
        
        /* شريط بحث سريع */
        .search-box {
            position: sticky;
            top: 0;
            z-index: 10;
            background: inherit;
            padding: 1rem;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .dark .search-box {
            border-bottom-color: #334155;
        }
    </style>
</head>
<body class="bg-gray-100 dark:bg-pixelDark text-slate-900 dark:text-slate-100 min-h-screen overflow-hidden">
    <div class="flex h-screen">
        <%- include('partials/sidebar') %>

        <main class="flex-1 flex flex-col min-h-screen">
            <%- include('partials/navbar') %>

            <div class="flex flex-1 gap-4 p-4 overflow-hidden">
                
                <!-- الجانب الأيمن: المنتجات (قابلة للتمرير) -->
                <div class="flex-[2] flex flex-col gap-4 overflow-hidden">
                    <!-- حقل الباركود -->
                    <div class="bg-white dark:bg-pixelCard p-4 rounded-3xl shadow-sm border border-gray-100 dark:border-slate-800 relative sticky top-0 z-20">
                        <div class="relative">
                            <i data-lucide="scan-barcode" class="absolute right-4 top-1/2 -translate-y-1/2 text-blue-500 animate-pulse"></i>
                            <input type="text" id="barcodeScannerInput" autofocus autocomplete="off" placeholder="مرر جهاز الباركود الآن..." 
                                class="w-full pr-12 pl-4 py-4 bg-gray-50 dark:bg-slate-900 rounded-2xl border-2 border-transparent focus:border-blue-500 outline-none transition-all font-bold text-lg">
                            <div id="barcodeErrorMsg" class="barcode-error-msg">❌ باركود غير مسجل</div>
                        </div>
                    </div>

                    <!-- شريط البحث السريع -->
                    <div class="bg-white dark:bg-pixelCard p-4 rounded-3xl shadow-sm border border-gray-100 dark:border-slate-800 search-box">
                        <div class="relative">
                            <i data-lucide="search" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input type="text" id="quickSearch" placeholder="ابحث عن منتج..." 
                                class="w-full pr-12 pl-4 py-3 bg-gray-50 dark:bg-slate-900 rounded-2xl border border-transparent focus:border-blue-500 outline-none transition-all">
                        </div>
                    </div>

                    <!-- شبكة المنتجات (مع شريط تمرير) -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 overflow-y-auto custom-scroll pb-10" id="productsGrid">
                        <% products.forEach(product => { %>
                            <button 
                                data-id="<%= product.id %>"
                                data-barcode="<%= product.barcode %>"
                                data-name="<%= product.name %>"
                                data-category="<%= product.Category ? product.Category.name : 'غير مصنف' %>"
                                data-price="<%= product.salePrice %>"
                                data-stock="<%= product.currentStock %>"
                                class="product-item bg-white dark:bg-pixelCard p-5 rounded-[2rem] border border-gray-100 dark:border-slate-800 transition-all text-right shadow-sm group relative overflow-hidden hover:shadow-xl hover:border-blue-200 dark:hover:border-blue-800">
                                
                                <div class="flex justify-between items-start mb-3">
                                    <span class="bg-blue-100 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-wider">
                                        <i data-lucide="barcode" class="inline w-3 h-3 ml-1"></i>
                                        <%= product.barcode %>
                                    </span>
                                    <span class="bg-gray-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 text-xs font-bold px-3 py-1.5 rounded-full">
                                        <i data-lucide="package" class="inline w-3 h-3 ml-1"></i>
                                        <%= product.currentStock %>
                                    </span>
                                </div>
                                
                                <div class="flex items-center gap-2 mb-3">
                                    <h3 class="text-xl font-black line-clamp-1 group-hover:text-blue-500 transition-colors flex-1">
                                        <%= product.name %>
                                    </h3>
                                    <div class="flex items-center gap-1 bg-blue-50 dark:bg-blue-500/10 px-2 py-1 rounded-full shrink-0">
                                        <i data-lucide="tag" class="w-3 h-3 text-blue-500"></i>
                                        <span class="text-blue-600/80 dark:text-blue-400/80 text-[11px] font-bold">
                                            <%= product.Category ? product.Category.name : 'بدون تصنيف' %>
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="flex items-baseline justify-between">
                                    <span class="text-slate-400 text-sm">السعر:</span>
                                    <p class="text-2xl font-black text-blue-600 dark:text-blue-400">
                                        <%= parseFloat(product.salePrice).toLocaleString() %> 
                                        <small class="text-xs font-normal text-slate-500">د.ع</small>
                                    </p>
                                </div>
                            </button>
                        <% }) %>
                    </div>
                </div>

                <!-- الجانب الأيسر: الفاتورة (ثابتة ولا تتحرك) -->
                <div class="flex-1 cart-sidebar">
                    <div class="bg-white dark:bg-pixelCard rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 flex flex-col h-full">
                        
                        <!-- رأس الفاتورة -->
                        <div class="cart-header p-6">
                            <div class="flex justify-between items-center">
                                <h2 class="text-xl font-black italic flex items-center gap-2 text-white">
                                    <i data-lucide="shopping-cart" class="w-6 h-6"></i> 
                                    الفاتورة الحالية
                                </h2>
                                <button onclick="clearCart()" class="bg-white/20 hover:bg-white/30 text-white p-2 rounded-xl transition-all backdrop-blur-sm">
                                    <i data-lucide="trash-2" class="w-5 h-5"></i>
                                </button>
                            </div>
                            
                            <!-- ملخص سريع -->
                            <div class="flex justify-between mt-4 text-white/80 text-sm">
                                <span>عدد الأصناف: <span id="itemCount" class="font-bold text-white">0</span></span>
                                <span>إجمالي القطع: <span id="totalQuantity" class="font-bold text-white">0</span></span>
                            </div>
                        </div>

                        <!-- محتويات الفاتورة (قابلة للتمرير) -->
                        <div class="flex-1 overflow-y-auto p-4 custom-scroll" id="cartItems" style="max-height: 400px;">
                            <div id="emptyCartMsg" class="h-full flex flex-col items-center justify-center opacity-20 italic text-center">
                                <i data-lucide="shopping-bag" class="w-16 h-16 mb-2"></i>
                                <p class="text-sm">امسح الباركود لإضافة مواد</p>
                            </div>
                        </div>

                        <!-- أسفل الفاتورة (الحقول الثابتة) -->
                        <div class="cart-footer p-6">
                            <div class="flex flex-col gap-3">
                                <select id="customerId" class="w-full p-3 bg-white dark:bg-pixelCard border border-gray-200 dark:border-slate-800 rounded-xl font-bold outline-none focus:ring-2 focus:ring-blue-500">
                                    <option value="">زبون نقدي</option>
                                    <% customers.forEach(c => { %> <option value="<%= c.id %>"><%= c.name %></option> <% }) %>
                                </select>

                                <div class="grid grid-cols-2 gap-2">
                                    <select id="paymentType" onchange="togglePaymentMode()" class="p-3 bg-white dark:bg-pixelCard border border-gray-200 dark:border-slate-800 rounded-xl font-bold">
                                        <option value="CASH">💰 نقدي</option>
                                        <option value="DEBT">📝 آجل</option>
                                    </select>
                                    <input type="number" id="paidAmount" placeholder="المبلغ المدفوع" 
                                        class="w-full p-3 bg-white dark:bg-pixelCard border border-gray-200 dark:border-slate-800 rounded-xl font-bold text-left"
                                        dir="ltr">
                                </div>

                                <div class="flex justify-between items-center py-4 border-t-2 border-dashed border-gray-300 dark:border-slate-700 mt-2">
                                    <span class="text-lg font-black italic">الإجمالي:</span>
                                    <div class="text-left font-black text-blue-600 text-3xl" id="cartTotal">0</div>
                                </div>

                                <div class="flex gap-2">
                                    <button onclick="quickPayment()" class="flex-1 bg-green-600 hover:bg-green-700 text-white py-3 rounded-xl font-bold transition-all">
                                        <i data-lucide="zap" class="inline w-4 h-4 ml-1"></i>
                                        دفع سريع
                                    </button>
                                    <button onclick="submitSale()" id="btnSubmit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl font-bold shadow-xl transition-all active:scale-95">
                                        <i data-lucide="save" class="inline w-4 h-4 ml-1"></i>
                                        حفظ (F2)
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>

      

        window.cart = [];

        const barcodeInput = document.getElementById('barcodeScannerInput');
        const errorMsg = document.getElementById('barcodeErrorMsg');
        const cartContainer = document.getElementById('cartItems');
        const cartTotalEl = document.getElementById('cartTotal');
        const emptyMsg = document.getElementById('emptyCartMsg');
        const itemCountEl = document.getElementById('itemCount');
        const totalQuantityEl = document.getElementById('totalQuantity');
        const quickSearch = document.getElementById('quickSearch');

        function calculateTotal() {
            return window.cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
        }

        function calculateStats() {
            const count = window.cart.length;
            const totalQty = window.cart.reduce((sum, item) => sum + item.quantity, 0);
            return { count, totalQty };
        }

        function addToCart(productId, productName, productPrice, availableStock) {
            const existing = window.cart.find(item => item.productId === productId);
            if (existing) {
                if (existing.quantity < availableStock) {
                    existing.quantity += 1;
                } else {
                    alert('⚠️ لا يوجد مخزون كافي');
                    return false;
                }
            } else {
                window.cart.push({
                    productId: productId,
                    name: productName,
                    price: productPrice,
                    quantity: 1,
                    stock: availableStock
                });
            }
            renderCart();
            return true;
        }

        function renderCart() {
            if (window.cart.length === 0) {
                emptyMsg.style.display = 'flex';
                cartContainer.innerHTML = '';
                cartTotalEl.innerText = '0';
                itemCountEl.innerText = '0';
                totalQuantityEl.innerText = '0';
                return;
            }

            emptyMsg.style.display = 'none';
            cartContainer.innerHTML = '';
            let total = 0;

            window.cart.forEach((item, index) => {
                const subtotal = item.price * item.quantity;
                total += subtotal;

                const cartItem = document.createElement('div');
                cartItem.className = 'bg-white dark:bg-slate-800 p-4 rounded-2xl border border-gray-100 dark:border-slate-700 flex justify-between items-center shadow-sm mb-2 hover:shadow-md transition-shadow';
                cartItem.innerHTML = `
                    <div class="flex-1 text-right">
                        <h4 class="font-bold text-sm text-slate-700 dark:text-slate-200 line-clamp-1">${item.name}</h4>
                        <p class="text-[10px] text-blue-500 font-black mt-1">
                            ${item.price.toLocaleString()} د.ع × ${item.quantity}
                        </p>
                    </div>
                    <div class="flex items-center gap-2 bg-gray-50 dark:bg-pixelDark p-1 rounded-xl ml-2">
                        <button onclick="updateQuantity(${index}, 1)" class="w-7 h-7 rounded-lg bg-white dark:bg-pixelCard shadow-sm flex items-center justify-center hover:text-blue-500 transition-colors text-lg font-bold">+</button>
                        <span class="w-6 text-center font-black text-sm">${item.quantity}</span>
                        <button onclick="updateQuantity(${index}, -1)" class="w-7 h-7 rounded-lg bg-white dark:bg-pixelCard shadow-sm flex items-center justify-center hover:text-red-500 transition-colors text-lg font-bold">-</button>
                    </div>
                    <div class="min-w-[70px] text-left">
                        <span class="font-black text-sm text-slate-500">${subtotal.toLocaleString()}</span>
                    </div>
                `;
                cartContainer.appendChild(cartItem);
            });

            cartTotalEl.innerText = total.toLocaleString();
            
            const stats = calculateStats();
            itemCountEl.innerText = stats.count;
            totalQuantityEl.innerText = stats.totalQty;
            
            if (document.getElementById('paymentType').value === 'CASH') {
                document.getElementById('paidAmount').value = total;
            }
        }

        window.updateQuantity = function(index, delta) {
            const item = window.cart[index];
            if (!item) return;
            if (delta > 0 && item.quantity >= item.stock) {
                alert('⚠️ لا توجد كمية كافية');
                return;
            }
            item.quantity += delta;
            if (item.quantity <= 0) window.cart.splice(index, 1);
            renderCart();
        };

        window.clearCart = function() {
            if (confirm('تفريغ الفاتورة؟')) {
                window.cart = [];
                renderCart();
                barcodeInput.focus();
            }
        };

        window.quickPayment = function() {
            const total = calculateTotal();
            document.getElementById('paidAmount').value = total;
            submitSale();
        };

        window.submitSale = async function() {
            if (window.cart.length === 0) return alert('السلة فارغة');
            
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerText = 'جاري الحفظ...';

            const payload = {
                customerId: document.getElementById('customerId').value || null,
                type: document.getElementById('paymentType').value,
                paid: parseFloat(document.getElementById('paidAmount').value) || 0,
                items: window.cart.map(i => ({ productId: i.productId, quantity: i.quantity }))
            };

            try {
                const response = await fetch('/sales/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();
                if (result.success) {
                    alert('✅ تم حفظ الفاتورة بنجاح');
                    window.location.reload();
                } else {
                    alert('❌ فشل: ' + (result.message || 'خطأ غير معروف'));
                }
            } catch (err) {
                alert('❌ خطأ في الاتصال بالخادم');
            } finally {
                btn.disabled = false;
                btn.innerText = 'حفظ (F2)';
            }
        };

        window.togglePaymentMode = function() {
            const type = document.getElementById('paymentType').value;
            if (type === 'DEBT') {
                document.getElementById('paidAmount').value = 0;
            } else {
                const total = calculateTotal();
                document.getElementById('paidAmount').value = total;
            }
        };

        // البحث السريع
        quickSearch.addEventListener('input', function() {
            const term = this.value.toLowerCase().trim();
            document.querySelectorAll('.product-item').forEach(card => {
                const name = card.dataset.name.toLowerCase();
                const barcode = card.dataset.barcode.toLowerCase();
                const category = card.dataset.category.toLowerCase();
                
                if (term === '') {
                    card.style.display = 'block';
                } else {
                    card.style.display = (name.includes(term) || barcode.includes(term) || category.includes(term)) ? 'block' : 'none';
                }
            });
        });

        // معالجة الباركود
        function handleBarcode(barcode) {
            if (!barcode.trim()) return;
            const productBtn = Array.from(document.querySelectorAll('.product-item:not([style*="display: none"])'))
                .find(btn => btn.dataset.barcode === barcode.trim());
            
            if (productBtn) {
                errorMsg.classList.remove('show');
                const { id, name, price, stock } = productBtn.dataset;
                addToCart(id, name, parseFloat(price), parseFloat(stock));
                productBtn.classList.add('flash-success');
                setTimeout(() => productBtn.classList.remove('flash-success'), 400);
                
                // تمرير تلقائي للمنتج المضاف
                productBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else {
                errorMsg.classList.add('show');
                setTimeout(() => errorMsg.classList.remove('show'), 2000);
            }
        }

        barcodeInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const barcode = barcodeInput.value.trim();
                if (barcode) handleBarcode(barcode);
                barcodeInput.value = '';
            }
        });

        let scanTimer;
        barcodeInput.addEventListener('input', function() {
            if (scanTimer) clearTimeout(scanTimer);
            scanTimer = setTimeout(() => {
                const barcode = this.value.trim();
                if (barcode) {
                    handleBarcode(barcode);
                    this.value = '';
                }
            }, 300);
        });

        document.querySelectorAll('.product-item').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const { id, name, price, stock } = this.dataset;
                addToCart(id, name, parseFloat(price), parseFloat(stock));
                this.classList.add('flash-success');
                setTimeout(() => this.classList.remove('flash-success'), 400);
            });
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'F2') { e.preventDefault(); submitSale(); }
            if (e.key === 'F4') { e.preventDefault(); clearCart(); }
            if (e.key === '/' && !e.ctrlKey && !e.altKey) { 
                e.preventDefault(); 
                quickSearch.focus(); 
            }
        });

        window.addEventListener('load', function() {
            if (typeof lucide !== 'undefined') lucide.createIcons();
            barcodeInput.value = '';
            barcodeInput.focus();
        });
    </script>
</body>
</html>