<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
    <style>
        * { box-sizing: border-box; }

        body {
            background: #0f172a;
            color: #f1f5f9;
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }

        /* ===== Layout ===== */
        .layout { display: flex; height: 100vh; overflow: hidden; }
        .main-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }
        .page-scroll { flex: 1; overflow-y: auto; }
        .page-scroll::-webkit-scrollbar { width: 4px; }
        .page-scroll::-webkit-scrollbar-thumb { background: #3b82f6; border-radius: 10px; }

        /* ===== رأس التقرير ===== */
        .report-header {
            background: linear-gradient(135deg, #1e3a5f 0%, #1e293b 60%, #0f172a 100%);
            border-bottom: 1px solid #1e3a5f;
            padding: 20px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
            position: sticky;
            top: 0;
            z-index: 20;
        }

        .report-header-left { display: flex; align-items: center; gap: 14px; }

        .report-icon {
            width: 44px;
            height: 44px;
            background: rgba(59,130,246,0.15);
            border: 1px solid rgba(59,130,246,0.3);
            border-radius: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #3b82f6;
            flex-shrink: 0;
        }

        .report-title {
            font-size: 20px;
            font-weight: 900;
            font-style: italic;
            background: linear-gradient(135deg, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .report-period {
            color: #475569;
            font-size: 12px;
            margin-top: 2px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .report-period svg { width: 12px; height: 12px; color: #3b82f6; }

        /* أزرار التحكم */
        .action-btns { display: flex; gap: 8px; }

        .action-btn {
            padding: 8px 16px;
            border-radius: 10px;
            border: 1px solid #334155;
            background: #0f172a;
            color: #94a3b8;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .action-btn:hover { border-color: #3b82f6; color: #3b82f6; background: rgba(59,130,246,0.05); }
        .action-btn svg { width: 14px; height: 14px; }
        .action-btn.primary { background: #3b82f6; color: white; border-color: #3b82f6; }
        .action-btn.primary:hover { background: #2563eb; }

        /* ===== قسم الفلتر ===== */
        .filter-section {
            background: #1e293b;
            border-bottom: 1px solid #334155;
            padding: 16px 28px;
            flex-shrink: 0;
        }

        .filter-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 90px 90px 140px 140px auto;
            gap: 10px;
            align-items: end;
        }

        .filter-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #475569;
            margin-bottom: 5px;
        }

        .filter-control {
            width: 100%;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 9px;
            color: #e2e8f0;
            padding: 9px 12px;
            font-size: 13px;
            font-weight: 600;
            outline: none;
            transition: border-color 0.2s;
            appearance: none;
            -webkit-appearance: none;
        }

        .filter-control:focus { border-color: #3b82f6; }
        .filter-control option { background: #1e293b; }

        .filter-btn {
            width: 100%;
            padding: 9px 16px;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            border: none;
            border-radius: 9px;
            color: white;
            font-size: 13px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .filter-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(59,130,246,0.4); }
        .filter-btn svg { width: 14px; height: 14px; }

        /* ===== محتوى الصفحة ===== */
        .page-body { padding: 24px 28px; }

        /* ===== بطاقات الإحصاء ===== */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 14px;
            margin-bottom: 24px;
        }

        .kpi-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 18px;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s, transform 0.2s;
        }

        .kpi-card:hover { border-color: var(--kc, #3b82f6); transform: translateY(-2px); }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 80px;
            height: 80px;
            background: radial-gradient(circle, var(--kg, rgba(59,130,246,0.12)), transparent 70%);
            border-radius: 50%;
        }

        .kpi-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: #64748b;
            margin-bottom: 8px;
        }

        .kpi-value {
            font-size: 22px;
            font-weight: 900;
            color: var(--kc, #3b82f6);
            line-height: 1.1;
        }

        .kpi-sub {
            font-size: 11px;
            color: #475569;
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .kpi-icon {
            position: absolute;
            top: 16px;
            left: 16px;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: var(--kg, rgba(59,130,246,0.12));
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--kc, #3b82f6);
        }

        .kpi-icon svg { width: 18px; height: 18px; }

        /* نسبة التغيير */
        .kpi-badge {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: 10px;
            font-weight: 800;
            padding: 2px 7px;
            border-radius: 50px;
        }

        .kpi-badge.up { background: rgba(34,197,94,0.1); color: #22c55e; }
        .kpi-badge.down { background: rgba(239,68,68,0.1); color: #ef4444; }
        .kpi-badge.neu { background: rgba(100,116,139,0.1); color: #64748b; }

        /* ===== قسم المخططات ===== */
        .charts-row {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 16px;
            margin-bottom: 20px;
        }

        .charts-row-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 20px;
        }

        .chart-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 20px;
        }

        .chart-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .chart-card-title {
            font-size: 14px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 8px;
            color: #e2e8f0;
        }

        .chart-card-title svg { width: 16px; height: 16px; }

        .chart-pill {
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 7px;
            padding: 4px 10px;
            font-size: 10px;
            font-weight: 700;
            color: #64748b;
        }

        .chart-box {
            position: relative;
            height: 220px;
        }

        .chart-box-sm { height: 180px; }

        /* ===== جدول المبيعات ===== */
        .table-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .table-card-header {
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #334155;
        }

        .table-card-title {
            font-size: 14px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 8px;
            color: #e2e8f0;
        }

        .table-card-title svg { width: 16px; height: 16px; color: #3b82f6; }

        .table-count {
            background: rgba(59,130,246,0.12);
            color: #3b82f6;
            font-size: 11px;
            font-weight: 800;
            padding: 3px 10px;
            border-radius: 50px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table thead tr {
            background: #0f172a;
        }

        .data-table thead th {
            padding: 11px 16px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #475569;
            text-align: right;
            border-bottom: 1px solid #334155;
            white-space: nowrap;
        }

        .data-table thead th:first-child { text-align: right; }
        .data-table thead th.t-center { text-align: center; }
        .data-table thead th.t-left { text-align: left; }

        .data-table tbody tr {
            border-bottom: 1px solid #1e293b;
            transition: background 0.15s;
        }

        .data-table tbody tr:hover { background: rgba(59,130,246,0.04); }
        .data-table tbody tr:last-child { border-bottom: none; }

        .data-table td {
            padding: 12px 16px;
            font-size: 13px;
            color: #94a3b8;
            text-align: right;
        }

        .data-table td.bold { font-weight: 700; color: #e2e8f0; }
        .data-table td.mono { font-family: monospace; }
        .data-table td.t-center { text-align: center; }
        .data-table td.t-left { text-align: left; }
        .data-table td.blue { color: #3b82f6; font-weight: 800; }
        .data-table td.green { color: #22c55e; font-weight: 700; }

        /* رقم الصف */
        .row-num {
            width: 24px;
            height: 24px;
            background: #0f172a;
            border-radius: 6px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 800;
            color: #334155;
        }

        /* شارات النوع */
        .type-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 700;
        }

        .type-cash { background: rgba(34,197,94,0.1); color: #22c55e; }
        .type-debt { background: rgba(239,68,68,0.1); color: #ef4444; }

        /* ===== جدول أفضل الزبائن ===== */
        .rank-num {
            width: 26px;
            height: 26px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 900;
        }

        .rank-1 { background: rgba(251,191,36,0.15); color: #fbbf24; }
        .rank-2 { background: rgba(148,163,184,0.15); color: #94a3b8; }
        .rank-3 { background: rgba(180,83,9,0.15); color: #b45309; }
        .rank-n { background: #0f172a; color: #475569; }

        /* ===== شريط الإجمالي السفلي ===== */
        .summary-bar {
            background: linear-gradient(135deg, #1e3a5f, #1e293b);
            border: 1px solid #1e3a5f;
            border-radius: 14px;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .summary-item { text-align: center; }
        .summary-item-label { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #475569; margin-bottom: 4px; }
        .summary-item-value { font-size: 18px; font-weight: 900; color: #3b82f6; }
        .summary-divider { width: 1px; height: 40px; background: #334155; }

        /* ===== فارغ ===== */
        .empty-row td {
            text-align: center;
            padding: 40px;
            color: #334155;
            font-size: 13px;
        }

        /* ===== طباعة ===== */
        @media print {
            body { background: white; color: black; }
            .no-print { display: none !important; }
            .report-header { position: static; background: white; border-bottom: 2px solid #e2e8f0; }
            .kpi-card, .chart-card, .table-card { background: white; border: 1px solid #e2e8f0; }
            .filter-section { display: none; }
        }

        /* ===== تمرير الجدول ===== */
        .table-scroll { overflow-x: auto; }
        .table-scroll::-webkit-scrollbar { height: 4px; }
        .table-scroll::-webkit-scrollbar-thumb { background: #3b82f6; border-radius: 10px; }
    </style>
</head>
<body>
<div class="layout">
    <%- include('partials/sidebar') %>

    <div class="main-area">
        <%- include('partials/navbar') %>

        <div class="page-scroll">

            <!-- ===== رأس التقرير ===== -->
            <div class="report-header no-print">
                <div class="report-header-left">
                    <div class="report-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    </div>
                    <div>
                        <div class="report-title">تقرير المبيعات التفصيلي</div>
                        <div class="report-period">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            الفترة: <%= data.period.from %> — <%= data.period.to %>
                        </div>
                    </div>
                </div>
                <div class="action-btns">
                    <a href="/reports" class="action-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        التقارير
                    </a>
                    <button onclick="exportReport('csv')" class="action-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        CSV
                    </button>
                    <button onclick="window.print()" class="action-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                        طباعة
                    </button>
                </div>
            </div>

            <!-- ===== الفلتر ===== -->
            <div class="filter-section no-print">
                <form id="filterForm" class="filter-grid">
                    <div>
                        <div class="filter-label">من تاريخ</div>
                        <input type="date" name="startDate" value="<%= data.filters.startDate %>" class="filter-control">
                    </div>
                    <div>
                        <div class="filter-label">إلى تاريخ</div>
                        <input type="date" name="endDate" value="<%= data.filters.endDate %>" class="filter-control">
                    </div>
                    <div>
                        <div class="filter-label">من ساعة</div>
                        <select name="shiftStart" class="filter-control">
                            <% for(let i=0;i<=23;i++){%><option value="<%=i%>"<%=data.filters.shiftStart==i?'selected':''%>><%=i%>:00</option><%}%>
                        </select>
                    </div>
                    <div>
                        <div class="filter-label">إلى ساعة</div>
                        <select name="shiftEnd" class="filter-control">
                            <% for(let i=0;i<=23;i++){%><option value="<%=i%>"<%=data.filters.shiftEnd==i?'selected':''%>><%=i%>:00</option><%}%>
                        </select>
                    </div>
                    <div>
                        <div class="filter-label">نوع البيع</div>
                        <select name="type" class="filter-control">
                            <option value="all" <%=data.filters.type==='all'?'selected':''%>>الكل</option>
                            <option value="CASH" <%=data.filters.type==='CASH'?'selected':''%>>💵 نقدي</option>
                            <option value="DEBT" <%=data.filters.type==='DEBT'?'selected':''%>>📋 آجل</option>
                        </select>
                    </div>
                    <div>
                        <div class="filter-label">الكاشير</div>
                        <select name="cashierId" class="filter-control">
                            <option value="all">الكل</option>
                            <% data.cashiers.forEach(c=>{%><option value="<%=c.id%>"<%=data.filters.cashierId==c.id?'selected':''%>><%=c.fullName%></option><%})%>
                        </select>
                    </div>
                    <div>
                        <div class="filter-label">&nbsp;</div>
                        <button type="submit" class="filter-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            تطبيق
                        </button>
                    </div>
                </form>
            </div>

            <!-- ===== محتوى الصفحة ===== -->
            <div class="page-body">

                <!-- شريط الملخص السريع -->
                <div class="summary-bar">
                    <div class="summary-item">
                        <div class="summary-item-label">إجمالي الإيرادات</div>
                        <div class="summary-item-value"><%= data.stats.totalSales.toLocaleString('ar-IQ') %> <small style="font-size:11px;color:#475569">د.ع</small></div>
                    </div>
                    <div class="summary-divider"></div>
                    <div class="summary-item">
                        <div class="summary-item-label">عدد الفواتير</div>
                        <div class="summary-item-value" style="color:#22c55e"><%= data.stats.totalInvoices %></div>
                    </div>
                    <div class="summary-divider"></div>
                    <div class="summary-item">
                        <div class="summary-item-label">متوسط الفاتورة</div>
                        <div class="summary-item-value" style="color:#a78bfa"><%= Math.round(data.stats.averageInvoice).toLocaleString('ar-IQ') %> <small style="font-size:11px;color:#475569">د.ع</small></div>
                    </div>
                    <div class="summary-divider"></div>
                    <div class="summary-item">
                        <div class="summary-item-label">النقدي</div>
                        <div class="summary-item-value" style="color:#22c55e"><%= data.stats.cashSales.toLocaleString('ar-IQ') %></div>
                    </div>
                    <div class="summary-divider"></div>
                    <div class="summary-item">
                        <div class="summary-item-label">الآجل</div>
                        <div class="summary-item-value" style="color:#ef4444"><%= data.stats.debtSales.toLocaleString('ar-IQ') %></div>
                    </div>
                    <div class="summary-divider"></div>
                    <div class="summary-item">
                        <div class="summary-item-label">مبيعات الوردية</div>
                        <div class="summary-item-value" style="color:#f59e0b"><%= data.shiftStats.total.toLocaleString('ar-IQ') %></div>
                    </div>
                </div>

                <!-- ===== بطاقات KPI ===== -->
                <div class="kpi-grid">

                    <!-- إجمالي المبيعات -->
                    <div class="kpi-card" style="--kc:#3b82f6;--kg:rgba(59,130,246,0.12)">
                        <div class="kpi-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                        </div>
                        <div class="kpi-label">إجمالي المبيعات</div>
                        <div class="kpi-value"><%= data.stats.totalSales.toLocaleString('ar-IQ') %></div>
                        <div class="kpi-sub">
                            <span class="kpi-badge up">▲ نشط</span>
                            <span><%= data.stats.totalInvoices %> فاتورة</span>
                        </div>
                    </div>

                    <!-- متوسط الفاتورة -->
                    <div class="kpi-card" style="--kc:#a855f7;--kg:rgba(168,85,247,0.12)">
                        <div class="kpi-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        </div>
                        <div class="kpi-label">متوسط الفاتورة</div>
                        <div class="kpi-value"><%= Math.round(data.stats.averageInvoice).toLocaleString('ar-IQ') %></div>
                        <div class="kpi-sub">
                            <span>≈ <%= Math.round(data.stats.averageInvoice/1000) %> ألف د.ع</span>
                        </div>
                    </div>

                    <!-- المبيعات النقدية -->
                    <div class="kpi-card" style="--kc:#22c55e;--kg:rgba(34,197,94,0.12)">
                        <div class="kpi-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                        </div>
                        <div class="kpi-label">المبيعات النقدية</div>
                        <div class="kpi-value"><%= data.stats.cashSales.toLocaleString('ar-IQ') %></div>
                        <div class="kpi-sub">
                            <span class="kpi-badge up">💵</span>
                            <span><%= data.stats.cashInvoices %> فاتورة</span>
                        </div>
                    </div>

                    <!-- المبيعات الآجلة -->
                    <div class="kpi-card" style="--kc:#ef4444;--kg:rgba(239,68,68,0.12)">
                        <div class="kpi-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <div class="kpi-label">المبيعات الآجلة</div>
                        <div class="kpi-value"><%= data.stats.debtSales.toLocaleString('ar-IQ') %></div>
                        <div class="kpi-sub">
                            <span class="kpi-badge down">📋</span>
                            <span><%= data.stats.debtInvoices %> فاتورة</span>
                        </div>
                    </div>

                    <!-- مبيعات الوردية -->
                    <div class="kpi-card" style="--kc:#f59e0b;--kg:rgba(245,158,11,0.12)">
                        <div class="kpi-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        </div>
                        <div class="kpi-label">مبيعات الوردية</div>
                        <div class="kpi-value"><%= data.shiftStats.total.toLocaleString('ar-IQ') %></div>
                        <div class="kpi-sub">
                            <span><%= data.shiftStats.startHour %>:00 — <%= data.shiftStats.endHour %>:00</span>
                        </div>
                    </div>

                </div>

                <!-- ===== المخططات: المبيعات اليومية + توزيع الساعات ===== -->
                <div class="charts-row">
                    <div class="chart-card">
                        <div class="chart-card-header">
                            <div class="chart-card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#3b82f6" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
                                المبيعات اليومية
                            </div>
                            <div class="chart-pill">خط البيان</div>
                        </div>
                        <div class="chart-box">
                            <canvas id="dailySalesChart"></canvas>
                        </div>
                    </div>

                    <div class="chart-card">
                        <div class="chart-card-header">
                            <div class="chart-card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#a855f7" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                توزيع الساعات
                            </div>
                            <div class="chart-pill">
                                <%
                                const peakHour = data.hourlySales && data.hourlySales.length
                                    ? data.hourlySales.reduce((mx,h)=>h.total>mx.total?h:mx,{total:0})
                                    : {hour:'—', total:0};
                                %>
                                ذروة: <%= peakHour.hour %>:00
                            </div>
                        </div>
                        <div class="chart-box chart-box-sm">
                            <canvas id="hourlySalesChart"></canvas>
                        </div>
                        <div style="margin-top:10px;font-size:11px;color:#475569;display:flex;justify-content:space-between">
                            <span>أعلى مبيعات: <strong style="color:#a855f7"><%= peakHour.hour %>:00</strong></span>
                            <span><%= peakHour.total.toLocaleString('ar-IQ') %> د.ع</span>
                        </div>
                    </div>
                </div>

                <!-- ===== أداء الكاشيرات + أفضل الزبائن ===== -->
                <div class="charts-row-2">

                    <!-- أداء الكاشيرات -->
                    <div class="chart-card">
                        <div class="chart-card-header">
                            <div class="chart-card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#22c55e" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                أداء الكاشيرات
                            </div>
                            <div class="chart-pill">أعمدة</div>
                        </div>
                        <div class="chart-box">
                            <canvas id="cashierChart"></canvas>
                        </div>
                    </div>

                    <!-- أفضل الزبائن -->
                    <div class="chart-card">
                        <div class="chart-card-header">
                            <div class="chart-card-title">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#f59e0b" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                أفضل الزبائن
                            </div>
                            <span class="table-count">أعلى 5</span>
                        </div>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th style="width:36px">#</th>
                                    <th>الزبون</th>
                                    <th class="t-center">فواتير</th>
                                    <th class="t-left">الإجمالي</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(data.topCustomers && data.topCustomers.length>0){ %>
                                    <% data.topCustomers.forEach((c,i)=>{ %>
                                    <tr>
                                        <td><span class="rank-num <%=i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-n'%>"><%=i+1%></span></td>
                                        <td class="bold"><%=c.name%></td>
                                        <td class="t-center"><%=c.invoices%></td>
                                        <td class="t-left green mono"><%=c.total.toLocaleString('ar-IQ')%></td>
                                    </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="empty-row"><td colspan="4">لا توجد بيانات</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- ===== جدول آخر المبيعات ===== -->
                <div class="table-card">
                    <div class="table-card-header">
                        <div class="table-card-title">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                            آخر المبيعات
                        </div>
                        <span class="table-count">50 فاتورة</span>
                    </div>
                    <div class="table-scroll">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th style="width:36px">#</th>
                                    <th>رقم الفاتورة</th>
                                    <th>التاريخ والوقت</th>
                                    <th>الزبون</th>
                                    <th>الكاشير</th>
                                    <th class="t-center">نوع الدفع</th>
                                    <th class="t-left">الإجمالي</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(data.recentSales && data.recentSales.length>0){ %>
                                    <% data.recentSales.forEach((s,i)=>{ %>
                                    <tr>
                                        <td><span class="row-num"><%=i+1%></span></td>
                                        <td class="mono" style="color:#60a5fa;font-weight:700">#<%=s.invoiceNumber%></td>
                                        <td style="font-size:12px">
                                            <div><%=new Date(s.date).toLocaleDateString('ar-IQ')%></div>
                                            <div style="color:#475569;font-size:10px"><%=new Date(s.date).toLocaleTimeString('ar-IQ',{hour:'2-digit',minute:'2-digit'})%></div>
                                        </td>
                                        <td class="bold"><%=s.customer%></td>
                                        <td style="font-size:12px;color:#64748b"><%=s.cashier%></td>
                                        <td class="t-center">
                                            <span class="type-badge <%=s.type==='CASH'?'type-cash':'type-debt'%>">
                                                <%=s.type==='CASH'?'💵 نقدي':'📋 آجل'%>
                                            </span>
                                        </td>
                                        <td class="t-left blue mono"><%=s.total.toLocaleString('ar-IQ')%> <small style="font-size:9px;color:#334155">د.ع</small></td>
                                    </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="empty-row"><td colspan="7">لا توجد مبيعات في هذه الفترة</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div><!-- /page-body -->
        </div><!-- /page-scroll -->
    </div><!-- /main-area -->
</div><!-- /layout -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const reportData = <%- JSON.stringify(data) %>;

    if (typeof lucide !== 'undefined') lucide.createIcons();

    // إعدادات Chart.js العامة (داكنة)
    Chart.defaults.color = '#64748b';
    Chart.defaults.borderColor = '#1e293b';
    Chart.defaults.font.family = "'Segoe UI', Tahoma, sans-serif";

    const GRID_COLOR = 'rgba(51,65,85,0.5)';

    document.addEventListener('DOMContentLoaded', () => {

        // ===== مخطط المبيعات اليومية =====
        const dailyCtx = document.getElementById('dailySalesChart')?.getContext('2d');
        if (dailyCtx && reportData.dailySales) {
            const grad = dailyCtx.createLinearGradient(0, 0, 0, 220);
            grad.addColorStop(0, 'rgba(59,130,246,0.3)');
            grad.addColorStop(1, 'rgba(59,130,246,0.02)');

            new Chart(dailyCtx, {
                type: 'line',
                data: {
                    labels: reportData.dailySales.map(d => d.date),
                    datasets: [{
                        label: 'المبيعات',
                        data: reportData.dailySales.map(d => d.total),
                        borderColor: '#3b82f6',
                        backgroundColor: grad,
                        borderWidth: 2.5,
                        tension: 0.45,
                        fill: true,
                        pointRadius: 3,
                        pointBackgroundColor: '#3b82f6',
                        pointBorderColor: '#0f172a',
                        pointBorderWidth: 2,
                        pointHoverRadius: 6,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            borderColor: '#334155',
                            borderWidth: 1,
                            titleColor: '#94a3b8',
                            bodyColor: '#e2e8f0',
                            padding: 10,
                            callbacks: {
                                label: ctx => ` ${ctx.parsed.y.toLocaleString('ar-IQ')} د.ع`
                            }
                        }
                    },
                    scales: {
                        x: { grid: { color: GRID_COLOR }, ticks: { maxTicksLimit: 8 } },
                        y: {
                            grid: { color: GRID_COLOR },
                            ticks: { callback: v => (v/1000).toFixed(0) + 'K' }
                        }
                    }
                }
            });
        }

        // ===== مخطط توزيع الساعات =====
        const hourlyCtx = document.getElementById('hourlySalesChart')?.getContext('2d');
        if (hourlyCtx && reportData.hourlySales) {
            const hours = [], values = [];
            for (let i = 6; i < 24; i++) {
                const h = reportData.hourlySales.find(x => x.hour === i);
                hours.push(i + ':00');
                values.push(h?.total || 0);
            }
            for (let i = 0; i < 6; i++) {
                const h = reportData.hourlySales.find(x => x.hour === i);
                hours.push(i + ':00');
                values.push(h?.total || 0);
            }

            const maxVal = Math.max(...values);
            const colors = values.map(v =>
                v === maxVal ? 'rgba(168,85,247,0.9)' : 'rgba(168,85,247,0.35)'
            );

            new Chart(hourlyCtx, {
                type: 'bar',
                data: {
                    labels: hours,
                    datasets: [{
                        data: values,
                        backgroundColor: colors,
                        borderRadius: 5,
                        borderSkipped: false,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            borderColor: '#334155',
                            borderWidth: 1,
                            bodyColor: '#e2e8f0',
                            callbacks: {
                                label: ctx => ` ${ctx.parsed.y.toLocaleString('ar-IQ')} د.ع`
                            }
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 9 }, maxRotation: 45 } },
                        y: { grid: { color: GRID_COLOR }, ticks: { callback: v => (v/1000).toFixed(0)+'K' } }
                    }
                }
            });
        }

        // ===== مخطط أداء الكاشيرات =====
        const cashierCtx = document.getElementById('cashierChart')?.getContext('2d');
        if (cashierCtx && reportData.byCashier) {
            const palette = ['#3b82f6','#22c55e','#f59e0b','#a855f7','#ef4444','#0ea5e9','#ec4899'];
            new Chart(cashierCtx, {
                type: 'bar',
                data: {
                    labels: reportData.byCashier.map(c => c.name),
                    datasets: [{
                        label: 'المبيعات',
                        data: reportData.byCashier.map(c => c.total),
                        backgroundColor: reportData.byCashier.map((_, i) => palette[i % palette.length]),
                        borderRadius: 8,
                        borderSkipped: false,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            borderColor: '#334155',
                            borderWidth: 1,
                            bodyColor: '#e2e8f0',
                            callbacks: {
                                label: ctx => ` ${ctx.parsed.y.toLocaleString('ar-IQ')} د.ع`
                            }
                        }
                    },
                    scales: {
                        x: { grid: { display: false } },
                        y: { grid: { color: GRID_COLOR }, ticks: { callback: v => (v/1000).toFixed(0)+'K' } }
                    }
                }
            });
        }
    });

    // ===== تصدير CSV =====
    function exportReport(format) {
        const form = document.getElementById('filterForm');
        const params = new URLSearchParams(new FormData(form));
        params.append('format', format);
        Swal.fire({
            title: 'جاري التصدير...',
            allowOutsideClick: false,
            background: '#1e293b',
            color: '#f1f5f9',
            didOpen: () => Swal.showLoading()
        });
        window.location.href = `/reports/sales/export?${params}`;
        setTimeout(() => Swal.close(), 1200);
    }
</script>
</body>
</html>
