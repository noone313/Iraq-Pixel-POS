<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
    <style>
        /* تحسينات التصميم الخاصة بسجل الفواتير */
        .invoice-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .invoice-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        .status-badge {
            padding: 6px 16px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .badge-cash {
            background-color: rgba(34, 197, 94, 0.1);
            color: #22c55e;
            border: 1px solid rgba(34, 197, 94, 0.2);
        }

        .badge-debt {
            background-color: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .custom-table-scroll::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        
        .custom-table-scroll::-webkit-scrollbar-thumb {
            background: #3b82f6;
            border-radius: 10px;
        }

        @media print {
            .no-print { display: none !important; }
            body { background: white !important; }
            .print-only { display: block !important; }
        }
    </style>
</head>
<body class="bg-slate-50 dark:bg-pixelDark text-slate-900 dark:text-slate-100 min-h-screen">
    <div class="flex">
        <%- include('partials/sidebar') %>
        
        <main class="flex-1 p-6 lg:p-10">

            <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-10 gap-6">
                <div class="animate-in fade-in slide-in-from-right duration-700">
                    <h1 class="text-4xl font-black italic text-blue-600 mb-2">🧾 سجل الفواتير والمبيعات</h1>
                    <p class="text-slate-500 font-bold flex items-center gap-2">
                        <i data-lucide="calendar" class="w-4 h-4"></i>
                        مراجعة أرشيف العمليات المالية الصادرة
                    </p>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 w-full lg:w-auto no-print">
                    <div class="bg-white dark:bg-pixelCard p-5 rounded-[2rem] border border-slate-200 dark:border-slate-800 shadow-sm text-center">
                        <span class="text-[10px] text-slate-400 font-black uppercase block mb-1">إجمالي الفواتير</span>
                        <span class="text-2xl font-black text-blue-600"><%= stats.totalInvoices %></span>
                    </div>
                    
                    <div class="bg-white dark:bg-pixelCard p-5 rounded-[2rem] border border-slate-200 dark:border-slate-800 shadow-sm text-center">
                        <span class="text-[10px] text-slate-400 font-black uppercase block mb-1">مجموع المبيعات</span>
                        <span class="text-2xl font-black text-emerald-500 tabular-nums"><%= stats.totalSalesAmount.toLocaleString() %></span>
                    </div>

                    <div class="bg-white dark:bg-pixelCard p-5 rounded-[2rem] border border-slate-200 dark:border-slate-800 shadow-sm text-center">
                        <span class="text-[10px] text-slate-400 font-black uppercase block mb-1">الديون المسجلة</span>
                        <span class="text-2xl font-black text-red-500 tabular-nums"><%= stats.totalDebtAmount.toLocaleString() %></span>
                    </div>

                    <button onclick="window.print()" class="bg-slate-900 text-white p-5 rounded-[2rem] shadow-lg hover:bg-slate-800 transition-all flex flex-col items-center justify-center gap-1">
                        <i data-lucide="printer" class="w-5 h-5"></i>
                        <span class="text-[10px] font-black uppercase">طباعة السجل</span>
                    </button>
                </div>
            </div>

            <div class="bg-white dark:bg-pixelCard rounded-[2.5rem] shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden animate-in fade-in zoom-in duration-500">
                
                <div class="p-6 border-b border-slate-100 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 no-print">
                    <div class="relative w-full md:w-1/2">
                        <i data-lucide="search" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 w-5 h-5"></i>
                        <input type="text" id="invoiceSearch" onkeyup="filterInvoices()" 
                            placeholder="ابحث برقم الفاتورة، اسم العميل، أو الكاشير..." 
                            class="w-full pr-12 pl-6 py-4 bg-slate-50 dark:bg-slate-900 rounded-[1.5rem] border-none outline-none font-bold text-sm focus:ring-2 focus:ring-blue-500 transition-all">
                    </div>

                    <div class="flex items-center gap-2 text-slate-400 text-xs font-bold">
                        <i data-lucide="info" class="w-4 h-4"></i>
                        يتم عرض آخر 500 عملية بيع
                    </div>
                </div>

                <div class="overflow-x-auto custom-table-scroll">
                    <table class="w-full text-right" id="invoiceTable">
                        <thead>
                            <tr class="bg-slate-50/50 dark:bg-slate-800/30 text-slate-400 text-[11px] font-black uppercase tracking-widest border-b border-slate-100 dark:border-slate-800">
                                <th class="p-6">رقم الفاتورة</th>
                                <th class="p-6">العميل</th>
                                <th class="p-6">التاريخ والوقت</th>
                                <th class="p-6">بواسطة</th>
                                <th class="p-6 text-center">نوع الدفع</th>
                                <th class="p-6">الإجمالي</th>
                                <th class="p-6">المدفوع</th>
                                <th class="p-6 text-left no-print">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50 dark:divide-slate-800">
                            <% sales.forEach(sale => { %>
                                <tr class="invoice-row group hover:bg-slate-50/80 dark:hover:bg-slate-800/40 transition-all">
                                    <td class="p-6">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-500/10 flex items-center justify-center text-blue-600 font-black text-xs">
                                                #<%= sale.invoiceNumber.slice(-3) %>
                                            </div>
                                            <span class="font-black text-slate-800 dark:text-white"><%= sale.invoiceNumber %></span>
                                        </div>
                                    </td>
                                    <td class="p-6">
                                        <div class="font-bold text-slate-700 dark:text-slate-200">
                                            <%= sale.Customer ? sale.Customer.name : '👤 زبون نقدي' %>
                                        </div>
                                    </td>
                                    <td class="p-6">
                                        <div class="text-xs text-slate-500 font-semibold tabular-nums">
                                            <%= new Date(sale.createdAt).toLocaleDateString('ar-IQ') %>
                                        </div>
                                        <div class="text-[10px] text-slate-400">
                                            <%= new Date(sale.createdAt).toLocaleTimeString('ar-IQ', { hour: '2-digit', minute: '2-digit' }) %>
                                        </div>
                                    </td>
                                    <td class="p-6">
                                        <span class="text-xs font-bold text-slate-500 bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-lg">
                                            <%= sale.User ? sale.User.fullName : 'النظام' %>
                                        </span>
                                    </td>
                                    <td class="p-6 text-center">
                                        <span class="status-badge <%= sale.type === 'CASH' ? 'badge-cash' : 'badge-debt' %>">
                                            <i data-lucide="<%= sale.type === 'CASH' ? 'banknote' : 'clock' %>" class="w-3 h-3"></i>
                                            <%= sale.type === 'CASH' ? 'نقدي' : 'آجل' %>
                                        </span>
                                    </td>
                                    <td class="p-6">
                                        <span class="font-black text-slate-800 dark:text-white tabular-nums">
                                            <%= Number(sale.total).toLocaleString() %>
                                        </span>
                                        <small class="text-[10px] text-slate-400 mr-1">د.ع</small>
                                    </td>
                                    <td class="p-6">
                                        <span class="font-black text-emerald-500 tabular-nums">
                                            <%= Number(sale.paid).toLocaleString() %>
                                        </span>
                                    </td>
                                    <td class="p-6 text-left no-print">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="/sales/view/<%= sale.id %>" class="p-2 bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-blue-500 rounded-xl transition-all" title="عرض التفاصيل">
                                                <i data-lucide="eye" class="w-4 h-4"></i>
                                            </a>
                                            <a href="/sales/print/<%= sale.id %>" target="_blank" class="p-2 bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-emerald-500 rounded-xl transition-all" title="إعادة طباعة">
                                                <i data-lucide="printer" class="w-4 h-4"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div id="noResults" class="hidden p-20 text-center flex flex-col items-center justify-center opacity-30">
                    <i data-lucide="search-x" class="w-16 h-16 mb-4"></i>
                    <p class="text-xl font-black">عذراً، لم يتم العثور على أي فاتورة مطابقة</p>
                </div>

                <% if (sales.length === 0) { %>
                    <div class="p-20 text-center flex flex-col items-center justify-center opacity-20">
                        <i data-lucide="inbox" class="w-20 h-20 mb-4"></i>
                        <p class="text-2xl font-black italic">السجل فارغ تماماً حالياً</p>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        // وظيفة البحث الذكي وتصفية الجدول
        function filterInvoices() {
            const input = document.getElementById('invoiceSearch');
            const filter = input.value.toLowerCase().trim();
            const rows = document.querySelectorAll('.invoice-row');
            const noResults = document.getElementById('noResults');
            const table = document.getElementById('invoiceTable');
            let foundCount = 0;

            rows.forEach(row => {
                const invoiceNum = row.querySelector('.font-black').innerText.toLowerCase();
                const customerName = row.querySelector('.font-bold').innerText.toLowerCase();
                const cashierName = row.querySelector('.bg-slate-100').innerText.toLowerCase();
                
                if (invoiceNum.includes(filter) || customerName.includes(filter) || cashierName.includes(filter)) {
                    row.style.display = "";
                    foundCount++;
                } else {
                    row.style.display = "none";
                }
            });

            // إظهار رسالة "لا توجد نتائج" إذا كان البحث فارغاً
            if (foundCount === 0 && filter !== "") {
                table.style.display = "none";
                noResults.classList.remove('hidden');
            } else {
                table.style.display = "table";
                noResults.classList.add('hidden');
            }
        }

        // تفعيل أيقونات لوسيد بعد تحميل الصفحة
        window.addEventListener('load', () => {
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        });
    </script>
</body>
</html>