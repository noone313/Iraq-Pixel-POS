<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-gray-50 dark:bg-pixelDark text-slate-900 dark:text-slate-100 min-h-screen">
    <div class="flex">
        <%- include('partials/sidebar') %>
        <main class="flex-1 flex flex-col min-h-screen overflow-hidden">
            <%- include('partials/navbar') %>

            <div class="flex-1 p-4 lg:p-8 overflow-y-auto">
                
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
                    <div>
                        <h1 class="text-3xl font-black italic uppercase tracking-tighter">
                            إدارة <span class="text-pixelBlue">المخزون</span>
                        </h1>
                        <p class="text-slate-500 font-medium mt-1">عرض وتعديل والبحث عن المنتجات</p>
                    </div>
                    <a href="/products/add" class="bg-pixelBlue hover:bg-blue-600 text-white px-6 py-3 rounded-2xl font-black shadow-lg shadow-blue-500/20 transition-all flex items-center gap-2">
                        <i data-lucide="plus-circle" class="w-5 h-5"></i>
                        منتج جديد
                    </a>
                     <a href="/products/trash" class="bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-2xl font-black shadow-lg shadow-red-500/20 transition-all flex items-center gap-2">
                        <i data-lucide="trash" class="w-5 h-5"></i>
                        سلة المحذوفات
                    </a>
                </div>

                <div class="bg-white dark:bg-pixelCard p-4 rounded-3xl shadow-sm border border-gray-100 dark:border-slate-800 mb-6">
                    <form action="/products" method="GET" class="flex flex-col md:flex-row gap-4">
                        <div class="relative flex-1 group">
                            <i data-lucide="search" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 group-focus-within:text-pixelBlue transition-colors"></i>
                            <input type="text" name="search" value="<%= searchQuery %>" 
                                placeholder="ابحث باسم المنتج أو الباركود..." 
                                class="w-full bg-gray-50 dark:bg-slate-900/50 border border-gray-200 dark:border-slate-800 p-4 pr-12 rounded-2xl focus:ring-2 focus:ring-pixelBlue/20 outline-none transition-all">
                        </div>
                        <button type="submit" class="bg-slate-900 dark:bg-pixelBlue text-white px-8 py-4 rounded-2xl font-bold hover:opacity-90 transition-all">
                            بحث سريع
                        </button>
                        <% if(searchQuery) { %>
                            <a href="/products" class="bg-red-50 text-red-500 px-4 py-4 rounded-2xl font-bold flex items-center justify-center border border-red-100">
                                <i data-lucide="x" class="w-5 h-5"></i>
                            </a>
                        <% } %>
                    </form>
                </div>

                <div class="bg-white dark:bg-pixelCard rounded-[2.5rem] shadow-2xl shadow-blue-900/5 border border-gray-100 dark:border-slate-800 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-right border-collapse">
                            <thead>
                                <tr class="bg-gray-50/50 dark:bg-slate-900/40 text-slate-400 uppercase text-xs font-black tracking-widest border-b border-gray-100 dark:border-slate-800">
                                    <th class="p-6">المنتج</th>
                                    <th class="p-6">الباركود</th>
                                    <th class="p-6 text-center">المخزون</th>
                                    <th class="p-6 text-center">السعر</th>
                                    <th class="p-6 text-center">الإجراءات</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50 dark:divide-slate-800">
                                <% products.forEach(product => { %>
                                    <tr class="hover:bg-blue-50/30 dark:hover:bg-blue-500/5 transition-colors">
                                        <td class="p-6">
                                            <div class="font-black text-lg text-slate-800 dark:text-slate-100"><%= product.name %></div>
                                            <div class="text-xs text-slate-400 italic">صنف: <%= product.Category ? product.Category.name : 'عام' %></div>
                                        </td>
                                        <td class="p-6">
                                            <span class="font-mono text-sm bg-gray-100 dark:bg-slate-800 px-3 py-1 rounded-lg text-slate-500"><%= product.barcode %></span>
                                        </td>
                                        <td class="p-6 text-center">
                                            <% const isLow = parseFloat(product.currentStock) <= parseFloat(product.minStockLevel); %>
                                            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-2xl font-black text-sm <%= isLow ? 'bg-red-100 text-red-600 animate-pulse' : 'bg-green-100 text-green-600' %>">
                                                <%= product.currentStock %>
                                                <span class="text-[10px] opacity-70"><%= product.unitType %></span>
                                            </div>
                                        </td>
                                        <td class="p-6 text-center">
                                            <div class="font-black text-pixelBlue text-lg"><%= product.salePrice %> <small class="text-[10px]">د.ع</small></div>
                                        </td>
                                        <td class="p-6">
                                            <div class="flex justify-center gap-3">
                                                <a href="/products/edit/<%= product.id %>" class="p-3 bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-pixelBlue hover:bg-pixelBlue/10 rounded-xl transition-all">
                                                    <i data-lucide="edit-3" class="w-5 h-5"></i>
                                                </a>
                                                <button onclick="deleteProduct('<%= product.id %>')" class="p-3 bg-gray-50 dark:bg-slate-800 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all">
                                                    <i data-lucide="trash-2" class="w-5 h-5"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="p-6 bg-gray-50/50 dark:bg-slate-900/20 border-t border-gray-100 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
                        <div class="text-sm text-slate-500 font-medium">
                            عرض <span class="font-black text-slate-900 dark:text-white"><%= products.length %></span> من أصل <span class="font-black text-slate-900 dark:text-white"><%= totalItems %></span> منتج
                        </div>
                        
                        <div class="flex items-center gap-2">
                            <% if (currentPage > 1) { %>
                                <a href="/products?page=<%= currentPage - 1 %>&search=<%= searchQuery %>" class="p-2 rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 hover:bg-pixelBlue hover:text-white transition-all">
                                    <i data-lucide="chevron-right" class="w-5 h-5"></i>
                                </a>
                            <% } %>

                            <div class="flex gap-1">
                                <% for(let i=1; i <= totalPages; i++) { %>
                                    <a href="/products?page=<%= i %>&search=<%= searchQuery %>" 
                                       class="w-10 h-10 flex items-center justify-center rounded-xl font-bold transition-all border <%= i === currentPage ? 'bg-pixelBlue text-white border-pixelBlue shadow-lg shadow-blue-500/20' : 'bg-white dark:bg-slate-800 border-gray-200 dark:border-slate-700 text-slate-500 hover:border-pixelBlue' %>">
                                        <%= i %>
                                    </a>
                                <% } %>
                            </div>

                            <% if (currentPage < totalPages) { %>
                                <a href="/products?page=<%= currentPage + 1 %>&search=<%= searchQuery %>" class="p-2 rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 hover:bg-pixelBlue hover:text-white transition-all">
                                    <i data-lucide="chevron-left" class="w-5 h-5"></i>
                                </a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('partials/footer') %>
        </main>
    </div>

    <script>
        lucide.createIcons();

        async function deleteProduct(id) {
            if(!confirm('هل أنت متأكد من نقل المنتج لسلة المحذوفات؟')) return;
            try {
                const response = await fetch(`/products/delete/${id}`, { method: 'POST' });
                const result = await response.json();
                if(result.success) window.location.reload();
                else alert(result.message);
            } catch (err) {
                alert('خطأ في الاتصال بالسيرفر');
            }
        }
    </script>
</body>
</html>