<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-gray-50 dark:bg-pixelDark text-slate-900 dark:text-slate-100 min-h-screen">
    <div class="flex">
        <%- include('partials/sidebar') %>
        <main class="flex-1 flex flex-col min-h-screen">
            <%- include('partials/navbar') %>

            <div class="flex-1 p-6 lg:p-12 flex flex-col items-center">
                <div class="w-full max-w-2xl flex flex-col items-center text-center mb-10">
                    <div class="mb-4 p-3 bg-pixelBlue/10 text-pixelBlue rounded-2xl w-fit border border-pixelBlue/5">
                        <i data-lucide="layout-grid" class="w-8 h-8"></i>
                    </div>
                    <h1 class="text-4xl font-black italic uppercase">إدارة <span class="text-pixelBlue">الأصناف</span></h1>
                    <p class="text-slate-500 mt-2">تنظيم المنتجات داخل أقسام لسهولة الجرد والبحث</p>
                </div>

                <div class="w-full max-w-2xl mb-8">
                    <form action="/categories" method="POST" class="flex gap-4 p-2 bg-white dark:bg-pixelCard rounded-[2rem] shadow-xl shadow-blue-900/5 border border-gray-100 dark:border-slate-800">
                        <input type="text" name="name" required placeholder="اكتب اسم الصنف الجديد... (مثل: مشروبات غازية)"
                            class="flex-1 bg-transparent p-4 pr-6 outline-none text-lg font-bold">
                        <button type="submit" class="bg-pixelBlue hover:bg-blue-600 text-white px-8 py-4 rounded-2xl font-bold transition-all hover:scale-105 active:scale-95 flex items-center gap-2">
                            <i data-lucide="plus" class="w-5 h-5"></i>
                            إضافة
                        </button>
                    </form>
                </div>

                <div class="w-full max-w-2xl bg-white dark:bg-pixelCard rounded-[2.5rem] shadow-2xl shadow-blue-900/5 border border-gray-100 dark:border-slate-800 overflow-hidden">
                    <div class="p-6 border-b border-gray-50 dark:border-slate-800/50 flex justify-between items-center">
                        <h3 class="font-black text-slate-400 uppercase text-sm tracking-widest">الأصناف المسجلة</h3>
                        <span class="bg-pixelBlue/10 text-pixelBlue px-3 py-1 rounded-full text-xs font-bold">
                            <%= categories.length %> صنف
                        </span>
                    </div>
                    
                    <div class="divide-y divide-gray-50 dark:divide-slate-800">
                        <% categories.forEach(cat => { %>
                        <div class="p-5 flex items-center justify-between hover:bg-gray-50/50 dark:hover:bg-slate-800/30 transition-colors group">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 group-hover:bg-pixelBlue/10 group-hover:text-pixelBlue transition-all">
                                    <i data-lucide="tag" class="w-5 h-5"></i>
                                </div>
                                <span class="text-lg font-bold text-slate-700 dark:text-slate-200"><%= cat.name %></span>
                            </div>
                            
                            <div class="flex items-center gap-2">
                                <button onclick="editCategory('<%= cat.id %>', '<%= cat.name %>')" class="p-2 text-slate-400 hover:text-pixelBlue hover:bg-pixelBlue/5 rounded-lg transition-all">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </button>
                                <button onclick="deleteCategory('<%= cat.id %>')" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </div>
                        <% }) %>
                        
                        <% if(categories.length === 0) { %>
                            <div class="p-10 text-center text-slate-400 font-medium">
                                لا توجد أصناف مضافة حالياً
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <%- include('partials/footer') %>
        </main>
    </div>

    <script>
    lucide.createIcons();

    // 1. تنفيذ طلب الحذف (DELETE)
    async function deleteCategory(id) {
        if (!confirm('عند حذف الصنف، قد تتأثر المنتجات المرتبطة به. هل أنت متأكد؟')) return;

        try {
            const response = await fetch(`/categories/${id}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const result = await response.json();

            if (result.success) {
                // تحديث الصفحة فوراً لرؤية النتيجة
                window.location.reload();
            } else {
                alert('خطأ: ' + result.message);
            }
        } catch (error) {
            console.error('Delete Error:', error);
            alert('حدث خطأ أثناء الاتصال بالسيرفر');
        }
    }

    // 2. تنفيذ طلب التعديل (POST)
    async function editCategory(id, currentName) {
        const newName = prompt('تعديل اسم الصنف:', currentName);
        
        // التحقق من أن الاسم الجديد ليس فارغاً ولم يتم إلغاء العملية
        if (newName && newName.trim() !== "" && newName !== currentName) {
            try {
                const response = await fetch(`/categories/${id}`, {
                    method: 'PUT', // كما طلبت، سنستخدم PUT للتعديل
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ name: newName.trim() })
                });

                const result = await response.json();

                if (result.success) {
                    window.location.reload();
                } else {
                    alert('خطأ في التعديل: ' + result.message);
                }
            } catch (error) {
                console.error('Update Error:', error);
                alert('حدث خطأ أثناء الاتصال بالسيرفر');
            }
        }
    }
</script>
</body>
</html>