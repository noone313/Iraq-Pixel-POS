<div class="bg-white dark:bg-pixelCard p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-slate-700 hover:scale-105 transition-transform">
    <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-4 
        <%= color === 'blue' ? 'bg-blue-100 dark:bg-blue-900/30 text-pixelBlue' : '' %>
        <%= color === 'green' ? 'bg-green-100 dark:bg-green-900/30 text-green-600' : '' %>
        <%= color === 'red' ? 'bg-red-100 dark:bg-red-900/30 text-red-500' : '' %>
        <%= color === 'purple' ? 'bg-purple-100 dark:bg-purple-900/30 text-purple-600' : '' %>">
        <i data-lucide="<%= icon %>"></i>
    </div>
    <h4 class="text-slate-500 text-sm font-semibold"><%= title %></h4>
    <div class="text-2xl font-bold mt-1">
        <%= typeof value === 'number' ? value.toLocaleString() : value %>
    </div>
</div>