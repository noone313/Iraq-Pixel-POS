<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <%- include('partials/head') %>
    <style>
        .input-field {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .input-field:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            transform: translateY(-1px);
        }
        /* تصميم مخصص لمفتاح التفعيل */
        .switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 26px;
        }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #cbd5e1;
            transition: .4s;
            border-radius: 34px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 18px; width: 18px;
            left: 4px; bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        input:checked + .slider { background-color: #3b82f6; }
        input:checked + .slider:before { transform: translateX(24px); }
    </style>
</head>
<body class="bg-gray-50 dark:bg-pixelDark text-slate-900 dark:text-slate-100 min-h-screen">

    <div class="flex">
        <%- include('partials/sidebar') %>

        <main class="flex-1 flex flex-col min-h-screen overflow-x-hidden">
            <%- include('partials/navbar') %>

            <div class="flex-1 p-6 lg:p-12 flex justify-center items-center">
                <div class="w-full max-w-2xl flex flex-col">
                    <div class="text-center mb-8 flex flex-col items-center">
                        <div class="mb-4 p-3 bg-pixelBlue/10 text-pixelBlue rounded-2xl w-fit border border-pixelBlue/5">
                            <i data-lucide="<%= mode === 'edit' ? 'user-cog' : 'shield-plus' %>" class="w-8 h-8"></i>
                        </div>
                        <h1 class="text-4xl md:text-5xl font-black tracking-tight italic uppercase leading-none">
                            PIXEL <span class="text-pixelBlue">IRAQ</span>
                        </h1>
                        <p class="text-slate-500 mt-3 font-medium text-lg">
                            <%= mode === 'edit' ? 'تعديل بيانات الموظف الحالي' : 'بوابة تسجيل المستخدمين والموظفين' %>
                        </p>
                    </div>

                    <div class="bg-white dark:bg-pixelCard p-8 lg:p-10 rounded-[2.5rem] shadow-2xl shadow-blue-900/5 border border-gray-200 dark:border-slate-800">
                        <form action="<%= mode === 'edit' ? '/update-user/' + user.id : '/register' %>" method="POST" class="space-y-6">
                            
                            <div class="space-y-2 text-right">
                                <label class="text-sm font-bold text-slate-600 dark:text-slate-400 mr-2 block">الاسم الكامل للموظف</label>
                                <div class="relative group">
                                    <i data-lucide="user" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 group-focus-within:text-pixelBlue transition-colors"></i>
                                    <input type="text" name="fullName" value="<%= user.fullName || '' %>" placeholder="مثال: محمد علي الكريم" required 
                                        class="input-field w-full pr-12 pl-4 py-4 bg-white dark:bg-slate-900 border-2 border-gray-200 dark:border-slate-700 rounded-2xl outline-none font-semibold">
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2 text-right">
                                    <label class="text-sm font-bold text-slate-600 dark:text-slate-400 mr-2 block">اسم المستخدم</label>
                                    <input type="text" name="username" value="<%= user.username || '' %>" placeholder="m_ali88" required 
                                        class="input-field w-full px-5 py-4 bg-white dark:bg-slate-900 border-2 border-gray-200 dark:border-slate-700 rounded-2xl outline-none font-semibold text-left">
                                </div>
                                <div class="space-y-2 text-right">
                                    <label class="text-sm font-bold text-slate-600 dark:text-slate-400 mr-2 block">الصلاحية</label>
                                    <div class="relative">
                                        <select name="role" class="input-field w-full px-5 py-4 bg-white dark:bg-slate-900 border-2 border-gray-200 dark:border-slate-700 rounded-2xl outline-none appearance-none font-semibold cursor-pointer">
                                            <option value="CASHIER" <%= user.role === 'CASHIER' ? 'selected' : '' %>>كاشير</option>
                                            <option value="ADMIN" <%= user.role === 'ADMIN' ? 'selected' : '' %>>مدير الحسابات</option>
                                            <option value="SUPER_ADMIN" <%= user.role === 'SUPER_ADMIN' ? 'selected' : '' %>>مدير عام</option>
                                        </select>
                                        <i data-lucide="chevron-down" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-slate-900/50 rounded-2xl border border-gray-100 dark:border-slate-800">
                                <div class="flex items-center gap-3">
                                    <div class="p-2 bg-white dark:bg-slate-800 rounded-lg shadow-sm">
                                        <i data-lucide="power" class="w-5 h-5 text-pixelBlue"></i>
                                    </div>
                                    <div>
                                        <span class="block font-bold text-sm">حالة الحساب</span>
                                        <span class="text-xs text-slate-500">تمكين أو تعطيل دخول الموظف للنظام</span>
                                    </div>
                                </div>
                                <label class="switch">
                                    <input type="checkbox" name="isActive" <%= (mode === 'create' || user.isActive) ? 'checked' : '' %>>
                                    <span class="slider"></span>
                                </label>
                            </div>

                            <div class="space-y-2 text-right">
                                <label class="text-sm font-bold text-slate-600 dark:text-slate-400 mr-2 block">
                                    <%= mode === 'edit' ? 'كلمة مرور جديدة (اتركها فارغة للمحافظة على الحالية)' : 'كلمة المرور' %>
                                </label>
                                <div class="relative group">
                                    <i data-lucide="lock" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 group-focus-within:text-pixelBlue transition-colors"></i>
                                    <input type="password" name="password" placeholder="••••••••" <%= mode === 'create' ? 'required' : '' %>
                                        class="input-field w-full pr-12 pl-4 py-4 bg-white dark:bg-slate-900 border-2 border-gray-200 dark:border-slate-700 rounded-2xl outline-none font-semibold">
                                </div>
                            </div>

                            <div class="pt-4">
                                <button type="submit" class="w-full bg-pixelBlue hover:bg-blue-600 text-white font-black py-5 rounded-2xl shadow-xl shadow-blue-500/30 transition-all active:scale-[0.97] flex items-center justify-center gap-3 text-lg group">
                                    <span><%= mode === 'edit' ? 'تحديث بيانات الموظف' : 'حفظ الموظف في النظام' %></span>
                                    <i data-lucide="<%= mode === 'edit' ? 'refresh-cw' : 'save' %>" class="w-6 h-6 group-hover:rotate-12 transition-transform"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <%- include('partials/footer') %>
        </main>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>